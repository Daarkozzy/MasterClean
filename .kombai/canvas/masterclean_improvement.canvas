      "html": "\n<div class=\"font-sans text-[var(--text-primary)] bg-[var(--bg-page)] selection:bg-[var(--blue-100)] selection:text-[var(--blue-900)]\" data-kid=\"0\">\n  \n  <link rel=\"stylesheet\" href=\"https://cdn.jsdelivr.net/npm/@tabler/icons-webfont/tabler-icons.min.css\" data-kid=\"1\">\n  \n  <style data-kid=\"2\">\n    @import url('https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&family=Outfit:wght@300;400;500;600;700;800;900&display=swap');\n\n    :root {\n      --white: #ffffff;\n      --off-white: #f8faff;\n      --gray-50: #f1f5fb;\n      --gray-100: #e4ecf7;\n      --gray-200: #c8d9ef;\n      --gray-400: #8fa3c0;\n      --gray-600: #4a6080;\n      --gray-800: #1e3050;\n      --gray-900: #0d1f38;\n      --blue-50: #eef4ff;\n      --blue-100: #dce9ff;\n      --blue-300: #6fa3f5;\n      --blue-500: #1a6ef5;\n      --blue-600: #0f59d4;\n      --blue-700: #0a46b0;\n      --blue-800: #063490;\n      --blue-900: #042470;\n      --gold-100: #fff8e1;\n      --gold-300: #fdd36a;\n      --gold-400: #f9b800;\n      --gold-500: #e8a800;\n      --gold-600: #c98900;\n      --bg-page: var(--white);\n      --bg-section: var(--off-white);\n      --bg-accent: var(--blue-50);\n      --bg-hero: var(--blue-900);\n      --text-primary: var(--gray-900);\n      --text-secondary: var(--gray-600);\n      --text-muted: var(--gray-400);\n      --text-on-dark: var(--white);\n      --brand-blue: var(--blue-600);\n      --brand-gold: var(--gold-400);\n      --brand-hover: var(--blue-700);\n      --font-sans: 'Inter', sans-serif;\n      --font-heading: 'Outfit', sans-serif;\n      --shadow-xs: 0 1px 3px rgba(13, 31, 56, 0.08);\n      --shadow-sm: 0 2px 8px rgba(13, 31, 56, 0.10);\n      --shadow-md: 0 6px 24px rgba(13, 31, 56, 0.12);\n      --shadow-lg: 0 16px 48px rgba(13, 31, 56, 0.15);\n      --shadow-xl: 0 24px 64px rgba(13, 31, 56, 0.20);\n      --shadow-blue: 0 4px 20px rgba(26, 110, 245, 0.30);\n      --shadow-gold: 0 4px 20px rgba(249, 184, 0, 0.35);\n      --transition-fast: all 0.18s ease;\n      --transition-normal: all 0.28s ease;\n      --transition-slow: all 0.45s ease;\n      --radius-sm: 8px;\n      --radius-md: 14px;\n      --radius-lg: 20px;\n      --radius-xl: 28px;\n      --radius-pill: 999px;\n    }\n\n    .font-heading { font-family: var(--font-heading); }\n    .font-sans { font-family: var(--font-sans); }\n\n    .glass-nav {\n      background: rgba(255, 255, 255, 0.85);\n      backdrop-filter: blur(16px);\n      -webkit-backdrop-filter: blur(16px);\n      border-bottom: 1px solid rgba(255, 255, 255, 0.4);\n      box-shadow: 0 4px 30px rgba(0, 0, 0, 0.05);\n    }\n\n    .hero-video-overlay {\n      background: linear-gradient(180deg, rgba(4, 36, 112, 0.9) 0%, rgba(4, 36, 112, 0.4) 100%);\n    }\n\n    .ticket-edge {\n      position: relative;\n    }\n    .ticket-edge::after {\n      content: '';\n      position: absolute;\n      bottom: -12px;\n      left: 0;\n      width: 100%;\n      height: 24px;\n      background-image: radial-gradient(circle at center, transparent 12px, var(--blue-900) 12px);\n      background-size: 28px 24px;\n      background-position: center;\n      background-repeat: repeat-x;\n    }\n\n    .glossy-card {\n      background: rgba(255, 255, 255, 0.9);\n      backdrop-filter: blur(10px);\n      border: 1px solid rgba(255, 255, 255, 0.4);\n      box-shadow: var(--shadow-xl);\n    }\n\n    \n    .watermark-icon {\n      position: absolute;\n      right: -20px;\n      bottom: -20px;\n      font-size: 180px;\n      opacity: 0.04;\n      pointer-events: none;\n      transform: rotate(-15deg);\n    }\n\n    .btn-glossy {\n      position: relative;\n      overflow: hidden;\n    }\n    .btn-glossy::after {\n      content: '';\n      position: absolute;\n      top: -50%;\n      left: -50%;\n      width: 200%;\n      height: 200%;\n      background: linear-gradient(45deg, transparent 0%, rgba(255,255,255,0.2) 50%, transparent 100%);\n      transform: rotate(45deg);\n      transition: 0.6s;\n    }\n    .btn-glossy:hover::after {\n      left: 100%;\n    }\n  </style>\n\n  \n  <nav class=\"absolute top-0 left-0 w-full z-50 glass-nav\" data-kid=\"3\">\n    <div class=\"max-w-[1440px] mx-auto px-8 h-20 flex items-center justify-between\" data-kid=\"4\">\n      <div class=\"flex items-center gap-2\" data-kid=\"5\">\n        <div class=\"w-10 h-10 bg-[var(--blue-600)] rounded-lg flex items-center justify-center shadow-lg shadow-blue-500/30\" data-kid=\"6\">\n          <i class=\"ti ti-sparkles text-white text-xl\" data-kid=\"7\"></i>\n        </div>\n        <span class=\"font-heading font-black text-2xl tracking-tight text-[var(--blue-900)]\" data-kid=\"8\">MASTER<span class=\"text-[var(--gold-500)]\" data-kid=\"9\">CLEAN</span></span>\n      </div>\n      \n      <div class=\"hidden lg:flex items-center gap-10\" data-kid=\"10\">\n        <a href=\"#\" class=\"font-heading font-semibold text-[var(--gray-800)] hover:text-[var(--blue-600)] transition-colors\" data-kid=\"11\">Início</a>\n        <a href=\"#\" class=\"font-heading font-semibold text-[var(--gray-800)] hover:text-[var(--blue-600)] transition-colors\" data-kid=\"12\">Serviços</a>\n        <a href=\"#\" class=\"font-heading font-semibold text-[var(--gray-800)] hover:text-[var(--blue-600)] transition-colors\" data-kid=\"13\">Resultados</a>\n        <a href=\"#\" class=\"font-heading font-semibold text-[var(--gray-800)] hover:text-[var(--blue-600)] transition-colors\" data-kid=\"14\">Preços</a>\n      </div>\n\n      <div class=\"flex items-center gap-4\" data-kid=\"15\">\n        <a href=\"tel:+551199999999\" class=\"hidden sm:flex items-center gap-2 font-heading font-bold text-[var(--blue-700)]\" data-kid=\"16\">\n          <i class=\"ti ti-brand-whatsapp text-2xl\" data-kid=\"17\"></i>\n          <span data-kid=\"18\">(11) 99999-9999</span>\n        </a>\n        <button class=\"bg-[var(--blue-600)] text-white px-6 py-2.5 rounded-full font-heading font-bold shadow-md hover:bg-[var(--blue-700)