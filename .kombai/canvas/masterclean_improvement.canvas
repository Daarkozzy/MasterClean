      "html": "<div class=\"masterclean-wrapper bg-white\" data-kid=\"0\">\n  <style data-kid=\"1\">\n    @import url('https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&family=Outfit:wght@300;400;500;600;700;800;900&display=swap');\n    @import url('https://cdn.jsdelivr.net/npm/@tabler/icons-webfont@latest/tabler-icons.min.css');\n\n    .masterclean-wrapper {\n      --white: #ffffff;\n      --off-white: #f8faff;\n      --gray-50: #f1f5fb;\n      --gray-100: #e4ecf7;\n      --gray-200: #c8d9ef;\n      --gray-400: #8fa3c0;\n      --gray-600: #4a6080;\n      --gray-800: #1e3050;\n      --gray-900: #0d1f38;\n      --blue-50: #eef4ff;\n      --blue-100: #dce9ff;\n      --blue-300: #6fa3f5;\n      --blue-500: #1a6ef5;\n      --blue-600: #0f59d4;\n      --blue-700: #0a46b0;\n      --brand-blue: var(--blue-600);\n      --brand-gold: #f9b800;\n      --gold-100: #fff8e1;\n      --gold-300: #fdd36a;\n      --font-sans: 'Inter', sans-serif;\n      --font-heading: 'Outfit', sans-serif;\n      --shadow-sm: 0 2px 8px rgba(13, 31, 56, 0.10);\n      --shadow-md: 0 6px 24px rgba(13, 31, 56, 0.12);\n      --radius-lg: 20px;\n      --radius-pill: 999px;\n      font-family: var(--font-sans);\n      color: var(--gray-900);\n      line-height: 1.6;\n    }\n\n    .masterclean-wrapper h1, \n    .masterclean-wrapper h2, \n    .masterclean-wrapper h3, \n    .masterclean-wrapper h4 {\n      font-family: var(--font-heading);\n      font-weight: 700;\n    }\n\n    .masterclean-wrapper .container {\n      max-width: 1200px;\n      margin: 0 auto;\n      padding: 0 24px;\n    }\n\n    .masterclean-wrapper .section-padding {\n      padding: 100px 0;\n    }\n\n    .masterclean-wrapper .section-eyebrow {\n      display: inline-block;\n      font-family: var(--font-heading);\n      font-size: 0.75rem;\n      font-weight: 800;\n      text-transform: uppercase;\n      letter-spacing: 2px;\n      color: var(--brand-blue);\n      background: var(--blue-50);\n      border: 1px solid var(--blue-100);\n      padding: 6px 16px;\n      border-radius: var(--radius-pill);\n      margin-bottom: 20px;\n    }\n\n    .masterclean-wrapper .section-title {\n      font-size: 2.75rem;\n      line-height: 1.1;\n      margin-bottom: 20px;\n      letter-spacing: -0.02em;\n    }\n\n    .masterclean-wrapper .btn-primary {\n      display: inline-flex;\n      align-items: center;\n      gap: 12px;\n      background: linear-gradient(135deg, var(--blue-500) 0%, var(--blue-700) 100%);\n      color: white;\n      padding: 16px 36px;\n      font-weight: 700;\n      border-radius: var(--radius-pill);\n      transition: all 0.3s ease;\n      box-shadow: 0 10px 25px -5px rgba(26, 110, 245, 0.4);\n      cursor: pointer;\n      border: none;\n    }\n\n    .masterclean-wrapper .btn-primary:hover {\n      transform: translateY(-2px);\n      box-shadow: 0 15px 30px -5px rgba(26, 110, 245, 0.5);\n    }\n\n    .masterclean-wrapper .btn-gold {\n      display: inline-flex;\n      align-items: center;\n      gap: 12px;\n      background: linear-gradient(135deg, var(--brand-gold) 0%, #e8a800 100%);\n      color: var(--gray-900);\n      padding: 16px 36px;\n      font-weight: 700;\n      border-radius: var(--radius-pill);\n      transition: all 0.3s ease;\n      box-shadow: 0 10px 25px -5px rgba(249, 184, 0, 0.4);\n      cursor: pointer;\n      border: none;\n    }\n\n    .masterclean-wrapper .card-premium {\n      background: white;\n      border: 1px solid var(--gray-100);\n      border-radius: 32px;\n      padding: 40px;\n      transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1);\n      box-shadow: var(--shadow-sm);\n    }\n\n    .masterclean-wrapper .card-premium:hover {\n      transform: translateY(-8px);\n      box-shadow: var(--shadow-md);\n      border-color: var(--blue-100);\n    }\n\n    .masterclean-wrapper .divider-line {\n      height: 1px;\n      background: linear-gradient(90deg, transparent 0%, var(--gray-100) 50%, transparent 100%);\n      margin: 40px 0;\n    }\n\n    .masterclean-wrapper .icon-accent {\n      position: relative;\n      display: inline-flex;\n      align-items: center;\n      justify-content: center;\n      width: 64px;\n      height: 64px;\n      background: var(--gray-50);\n      border-radius: 18px;\n      color: var(--gray-800);\n      margin-bottom: 24px;\n      border: 1px solid var(--gray-100);\n    }\n\n    .masterclean-wrapper .icon-accent::after {\n      content: '';\n      position: absolute;\n      top: -4px;\n      right: -4px;\n      width: 12px;\n      height: 12px;\n      background: var(--brand-gold);\n      border: 2.5px solid white;\n      border-radius: 50%;\n      box-shadow: 0 0 10px var(--brand-gold);\n    }\n\n    .masterclean-wrapper .calculator-input-row {\n      display: flex;\n      align-items: center;\n      justify-content: space-between;\n      padding: 16px 20px;\n      background: var(--gray-50);\n      border-radius: 16px;\n      border: 1px solid transparent;\n      transition: all 0.2s;\n    }\n\n    .masterclean-wrapper .calculator-input-row:hover {\n      border-color: var(--blue-100);\n      background: white;\n    }\n\n    .masterclean-wrapper .map-container {\n      background-image: radial-gradient(var(--gray-200) 1px, transparent 1px);\n      background-size: 20px 20px;\n    }\n  </style>\n\n  \n  <nav class=\"relative z-50 bg-white border-b border-gray-100\" data-kid=\"2\">\n    <div class=\"container h-20 flex items-center justify-between\" data-kid=\"3\">\n      <div class=\"flex items-center gap-3\" data-kid=\"4\">\n        <div class=\"w-10 h-10 bg-[var(--brand-blue)] rounded-xl flex items-center justify-center text-white shadow-lg shadow-blue-500/20\" data-kid=\"5\">\n          <i class=\"ti ti-sparkles text-2xl\" data-kid=\"6\"></i>\n        </div>\n        <span class=\"text-xl font-black tracking-tight text-[var(--gray-900)]\" data-kid=\"7\">MasterClean</span>\n      </div>\n      <div class=\"hidden md:flex items-center gap-8\" data-kid=\"8\">\n        <a href=\"#servicos\" class=\"text-sm font-semibold text-[var(--gray-600)] hover:text-[var(--brand-blue)] transition-colors\" data-kid=\"9\">Serviços</a>\n        <a href=\"#resultados\" class=\"text-sm font-semibold text-[var(--gray-600)] hover:text-[var(--brand-blue)] transition-colors\" data-kid=\"10\">Resultados</a>\n        <a href=\"#orcamento\" class=\"text-sm font-semibold text-[var(--gray-600)] hover:text-[var(--brand-blue)] transition-colors\" data-kid=\"11\">Orçamento</a>\n        <a href=\"#contato\" class=\"text-sm font-semibold text-[var(--gray-600)] hover:text-[var(--brand-blue)] transition-colors\" data-kid=\"12\">Contato</a>\n      </div>\n      <button class=\"btn-primary py-3 px-8 text-sm\" data-kid=\"13\">\n        <i class=\"ti ti-brand-whatsapp text-lg\" data-kid=\"14\"></i> Agendar Agora\n      </button>\n    </div>\n  </nav>\n\n  \n  <header class=\"relative overflow-hidden bg-white py-24 md:py-32\" data-kid=\"15\">\n    <div class=\"container relative z-10 grid md:grid-cols-2 gap-16 items-center\" data-kid=\"16\">\n      <div data-kid=\"17\">\n        <span class=\"section-eyebrow\" data-kid=\"18\">Higienização Profissional</span>\n        <h1 class=\"text-5xl md:text-7xl font-black text-[var(--gray-900)] leading-[1.05] mb-8\" data-kid=\"19\">\n          O Toque de <span class=\"text-[var(--brand-blue)]\" data-kid=\"20\">Luxo</span> que seu Lar Merece.\n        </h1>\n        <p class=\"text-xl text-[var(--gray-600)] mb-10 max-w-lg\" data-kid=\"21\">\n          Especialistas em limpeza técnica de estofados, tapetes e interiores automotivos com tecnologia de extração profunda.\n        </p>\n        <div class=\"flex flex-wrap gap-4\" data-kid=\"22\">\n          <button class=\"btn-primary\" data-kid=\"23\">Nossos Serviços <i class=\"ti ti-arrow-right\" data-kid=\"24\"></i></button>\n          <button class=\"flex items-center gap-3 px-8 py-4 font-bold text-[var(--gray-900)] hover:text-[var(--brand-blue)] transition-colors\" data-kid=\"25\">\n            <i class=\"ti ti-player-play-filled text-2xl text-[var(--brand-gold)]\" data-kid=\"26\"></i> Ver como funciona\n          </button>\n        </div>\n        <div class=\"mt-12 flex items-center gap-6\" data-kid=\"27\">\n          <div class=\"flex -space-x-3\" data-kid=\"28\">\n            <img src=\"https://i.pravatar.cc/100?u=1\" class=\"w-12 h-12 rounded-full border-4 border-white\" alt=\"Avatar\" decoding=\"async\" loading=\"lazy\" data-kid=\"29\">\n            <img src=\"https://i.pravatar.cc/100?u=2\" class=\"w-12 h-12 rounded-full border-4 border-white\" alt=\"Avatar\" decoding=\"async\" loading=\"lazy\" data-kid=\"30\">\n            <img src=\"https://i.pravatar.cc/100?u=3\" class=\"w-12 h-12 rounded-full border-4 border-white\" alt=\"Avatar\" decoding=\"async\" loading=\"lazy\" data-kid=\"31\">\n          </div>\n          <div class=\"text-sm\" data-kid=\"32\">\n            <div class=\"flex text-[var(--brand-gold)] mb-1\" data-kid=\"33\">\n              <i class=\"ti ti-star-filled\" data-kid=\"34\"></i><i class=\"ti ti-star-filled\" data-kid=\"35\"></i><i class=\"ti ti-star-filled\" data-kid=\"36\"></i><i class=\"ti ti-star-filled\" data-kid=\"37\"></i><i class=\"ti ti-star-filled\" data-kid=\"38\"></i>\n            </div>\n            <p class=\"font-bold\" data-kid=\"39\">+2.500 Clientes Satisfeitos</p>\n          </div>\n        </div>\n      </div>\n      <div class=\"relative\" data-kid=\"40\">\n        <div class=\"absolute inset-0 bg-blue-100/50 rounded-full blur-[120px] -z-10 animate-pulse\" data-kid=\"41\"></div>\n        <div class=\"rounded-3xl overflow-hidden shadow-2xl border-[12px] border-white rotate-2 transform transition-transform hover:rotate-0 duration-700\" data-kid=\"42\">\n          <img src=\"https://images.unsplash.com/photo-1621639532859-8b26570b96fc?auto=format&w=800&q=80&fit=crop\" alt=\"Limpeza de Luxo\" class=\"w-full h-[600px] object-cover\" decoding=\"async\" loading=\"lazy\" data-kid=\"43\">\n        </div>\n        <div class=\"absolute -bottom-8 -left-8 bg-white p-6 rounded-2xl shadow-xl border border-gray-100\" data-kid=\"44\">\n          <div class=\"flex items-center gap-4\" data-kid=\"45\">\n            <div class=\"w-12 h-12 bg-green-50 rounded-full flex items-center justify-center text-green-600\" data-kid=\"46\">\n              <i class=\"ti ti-virus-off text-2xl\" data-kid=\"47\"></i>\n            </div>\n            <div data-kid=\"48\">\n              <p class=\"text-xs font-bold text-gray-400 uppercase tracking-widest\" data-kid=\"49\">Proteção</p>\n              <p class=\"font-black text-gray-900\" data-kid=\"50\">99% Bactérias Removidas</p>\n            </div>\n          </div>\n        </div>\n      </div>\n    </div>\n  </header>\n\n  <div class=\"divider-line\" data-kid=\"51\"></div>\n\n  \n  <section id=\"servicos\" class=\"section-padding bg-[var(--off-white)]\" data-kid=\"52\">\n    <div class=\"container\" data-kid=\"53\">\n      <div class=\"text-center max-w-2xl mx-auto mb-16\" data-kid=\"54\">\n        <span class=\"section-eyebrow\" data-kid=\"55\">Nossas Especialidades</span>\n        <h2 class=\"section-title\" data-kid=\"56\">Serviços <span class=\"text-[var(--brand-blue)]\" data-kid=\"57\">Premium</span></h2>\n        <p class=\"text-[var(--gray-600)]\" data-kid=\"58\">Soluções completas de higienização para cada necessidade do seu cotidiano.</p>\n      </div>\n\n      <div class=\"grid grid-cols-1 md:grid-cols-3 gap-8\" data-kid=\"59\">\n        <div class=\"card-premium group\" data-kid=\"60\">\n          <div class=\"icon-accent group-hover:bg-[var(--brand-blue)] group-hover:text-white transition-colors duration-300\" data-kid=\"61\">\n            <i class=\"ti ti-sofa text-3xl\" data-kid=\"62\"></i>\n          </div>\n          <h3 class=\"text-2xl font-black mb-4\" data-kid=\"63\">Estofados Premium</h3>\n          <p class=\"text-[var(--gray-600)] mb-8\" data-kid=\"64\">Tratamento VIP para sofás e poltronas com tecnologia de secagem ultra-rápida.</p>\n          <ul class=\"space-y-4 mb-10\" data-kid=\"65\">\n            <li class=\"flex items-center gap-3 text-sm font-semibold\" data-kid=\"66\">\n              <i class=\"ti ti-circle-check-filled text-[var(--brand-gold)]\" data-kid=\"67\"></i> Higienização Profunda\n            </li>\n            <li class=\"flex items-center gap-3 text-sm font-semibold\" data-kid=\"68\">\n              <i class=\"ti ti-circle-check-filled text-[var(--brand-gold)]\" data-kid=\"69\"></i> Revitalização de Fibras\n            </li>\n          </ul>\n          <a href=\"#\" class=\"inline-flex items-center gap-2 font-bold text-[var(--brand-blue)] group-hover:gap-4 transition-all\" data-kid=\"70\">\n            Solicitar Orçamento <i class=\"ti ti-chevron-right\" data-kid=\"71\"></i>\n          </a>\n        </div>\n\n        <div class=\"card-premium group border-b-4 border-b-[var(--brand-gold)]\" data-kid=\"72\">\n          <div class=\"icon-accent group-hover:bg-[var(--brand-blue)] group-hover:text-white transition-colors duration-300\" data-kid=\"73\">\n            <i class=\"ti ti-car-clean text-3xl\" data-kid=\"74\"></i>\n          </div>\n          <h3 class=\"text-2xl font-black mb-4\" data-kid=\"75\">Auto Detailing</h3>\n          <p class=\"text-[var(--gray-600)] mb-8\" data-kid=\"76\">Seu carro com cheiro de novo. Limpeza técnica completa de interiores com bio-produtos.</p>\n          <ul class=\"space-y-4 mb-10\" data-kid=\"77\">\n            <li class=\"flex items-center gap-3 text-sm font-semibold\" data-kid=\"78\">\n              <i class=\"ti ti-circle-check-filled text-[var(--brand-gold)]\" data-kid=\"79\"></i> Hidratação de Couro\n            </li>\n            <li class=\"flex items-center gap-3 text-sm font-semibold\" data-kid=\"80\">\n              <i class=\"ti ti-circle-check-filled text-[var(--brand-gold)]\" data-kid=\"81\"></i> Sanitização de Cabine\n            </li>\n          </ul>\n          <a href=\"#\" class=\"inline-flex items-center gap-2 font-bold text-[var(--brand-blue)] group-hover:gap-4 transition-all\" data-kid=\"82\">\n            Solicitar Orçamento <i class=\"ti ti-chevron-right\" data-kid=\"83\"></i>\n          </a>\n        </div>\n\n        <div class=\"card-premium group\" data-kid=\"84\">\n          <div class=\"icon-accent group-hover:bg-[var(--brand-blue)] group-hover:text-white transition-colors duration-300\" data-kid=\"85\">\n            <i class=\"ti ti-bed text-3xl\" data-kid=\"86\"></i>\n          </div>\n          <h3 class=\"text-2xl font-black mb-4\" data-kid=\"87\">Saúde no Quarto</h3>\n          <p class=\"text-[var(--gray-600)] mb-8\" data-kid=\"88\">Proteção total contra ácaros e alérgenos em colchões e travesseiros.</p>\n          <ul class=\"space-y-4 mb-10\" data-kid=\"89\">\n            <li class=\"flex items-center gap-3 text-sm font-semibold\" data-kid=\"90\">\n              <i class=\"ti ti-circle-check-filled text-[var(--brand-gold)]\" data-kid=\"91\"></i> Eliminação de Ácaros\n            </li>\n            <li class=\"flex items-center gap-3 text-sm font-semibold\" data-kid=\"92\">\n              <i class=\"ti ti-circle-check-filled text-[var(--brand-gold)]\" data-kid=\"93\"></i> Acabamento Antialérgico\n            </li>\n          </ul>\n          <a href=\"#\" class=\"inline-flex items-center gap-2 font-bold text-[var(--brand-blue)] group-hover:gap-4 transition-all\" data-kid=\"94\">\n            Solicitar Orçamento <i class=\"ti ti-chevron-right\" data-kid=\"95\"></i>\n          </a>\n        </div>\n      </div>\n    </div>\n  </section>\n\n  <div class=\"divider-line\" data-kid=\"96\"></div>\n\n  \n  <section id=\"resultados\" class=\"section-padding bg-white overflow-hidden\" data-kid=\"97\">\n    <div class=\"container\" data-kid=\"98\">\n      <div class=\"text-center max-w-3xl mx-auto mb-16\" data-kid=\"99\">\n        <span class=\"section-eyebrow\" data-kid=\"100\">Resultados Reais</span>\n        <h2 class=\"section-title\" data-kid=\"101\">O Poder da Higienização Profunda</h2>\n        <p class=\"text-[var(--gray-600)]\" data-kid=\"102\">Veja a diferença drástica que nossa equipe MasterClean proporciona.</p>\n      </div>\n\n      <div class=\"relative max-w-5xl mx-auto\" data-kid=\"103\">\n        <div class=\"grid grid-cols-1 md:grid-cols-2 gap-6\" data-kid=\"104\">\n          <div class=\"relative rounded-2xl overflow-hidden group\" data-kid=\"105\">\n            <img src=\"https://images.unsplash.com/photo-1621639532859-8b26570b96fc?auto=format&w=800&q=80&fit=crop\" alt=\"Antes\" class=\"w-full h-[450px] object-cover grayscale brightness-50 contrast-125\" decoding=\"async\" loading=\"lazy\" data-kid=\"106\">\n            <div class=\"absolute top-6 left-6 bg-red-500 text-white text-xs font-black px-4 py-2 rounded-full uppercase tracking-widest\" data-kid=\"107\">Antes</div>\n          </div>\n          <div class=\"relative rounded-2xl overflow-hidden group\" data-kid=\"108\">\n            <img src=\"https://images.unsplash.com/photo-1621639532859-8b26570b96fc?auto=format&w=800&q=80&fit=crop\" alt=\"Depois\" class=\"w-full h-[450px] object-cover saturate-150\" decoding=\"async\" loading=\"lazy\" data-kid=\"109\">\n            <div class=\"absolute top-6 left-6 bg-green-500 text-white text-xs font-black px-4 py-2 rounded-full uppercase tracking-widest\" data-kid=\"110\">Depois</div>\n            <div class=\"absolute bottom-6 right-6 bg-white/90 backdrop-blur p-4 rounded-xl flex items-center gap-3\" data-kid=\"111\">\n              <i class=\"ti ti-sparkles text-[var(--brand-gold)] text-xl\" data-kid=\"112\"></i>\n              <span class=\"font-bold text-sm\" data-kid=\"113\">Toque de Luxo</span>\n            </div>\n          </div>\n        </div>\n      </div>\n    </div>\n  </section>\n\n  <div class=\"divider-line\" data-kid=\"114\"></div>\n\n  \n  <section class=\"section-padding bg-[var(--off-white)] relative overflow-hidden\" data-kid=\"115\">\n    <div class=\"absolute top-1/4 -left-24 w-96 h-96 bg-[var(--brand-blue)]/5 rounded-full blur-[100px]\" data-kid=\"116\"></div>\n    <div class=\"absolute bottom-1/4 -right-24 w-96 h-96 bg-[var(--brand-gold)]/5 rounded-full blur-[100px]\" data-kid=\"117\"></div>\n\n    <div class=\"container relative z-10\" data-kid=\"118\">\n      <div class=\"flex flex-col md:flex-row items-center gap-16\" data-kid=\"119\">\n        <div class=\"w-full md:w-1/2 relative\" data-kid=\"120\">\n          <div class=\"relative z-10 rounded-[40px] overflow-hidden shadow-2xl border-8 border-white\" data-kid=\"121\">\n            <img src=\"https://images.unsplash.com/photo-1621639532859-8b26570b96fc?auto=format&w=1200&q=80&fit=crop\" alt=\"Mascot Context\" class=\"w-full h-[550px] object-cover\" decoding=\"async\" loading=\"lazy\" data-kid=\"122\">\n            <div class=\"absolute inset-0 bg-gradient-to-t from-black/60 to-transparent\" data-kid=\"123\"></div>\n            <div class=\"absolute bottom-10 left-10 right-10\" data-kid=\"124\">\n              <div class=\"bg-white/10 backdrop-blur-md border border-white/20 p-6 rounded-3xl\" data-kid=\"125\">\n                <div class=\"flex items-center gap-5\" data-kid=\"126\">\n                  <div class=\"w-14 h-14 bg-[var(--brand-gold)] rounded-2xl flex items-center justify-center text-white text-2xl\" data-kid=\"127\">\n                    <i class=\"ti ti-shield-check\" data-kid=\"128\"></i>\n                  </div>\n                  <div data-kid=\"129\">\n                    <h4 class=\"text-white text-xl font-black\" data-kid=\"130\">Selo MasterClean</h4>\n                    <p class=\"text-white/70 text-sm\" data-kid=\"131\">Excelência Técnica Certificada</p>\n                  </div>\n                </div>\n              </div>\n            </div>\n          </div>\n        </div>\n        <div class=\"w-full md:w-1/2\" data-kid=\"132\">\n          <span class=\"section-eyebrow\" data-kid=\"133\">Compromisso com a Saúde</span>\n          <h2 class=\"section-title text-4xl md:text-5xl\" data-kid=\"134\">Mais que uma <span class=\"text-[var(--brand-blue)]\" data-kid=\"135\">Limpeza Visual</span>.</h2>\n          <p class=\"text-lg text-[var(--gray-600)] mb-10 leading-relaxed\" data-kid=\"136\">\n            Ácaros e bactérias são invisíveis, mas afetam sua saúde. Nossa missão é devolver a pureza ao seu ambiente com processos que eliminam 99,9% dos microrganismos.\n          </p>\n          <div class=\"space-y-6 mb-12\" data-kid=\"137\">\n            <div class=\"flex items-start gap-5 p-6 bg-white rounded-2xl border border-gray-100 shadow-sm\" data-kid=\"138\">\n              <div class=\"w-12 h-12 bg-blue-50 text-[var(--brand-blue)] rounded-xl flex items-center justify-center shrink-0\" data-kid=\"139\">\n                <i class=\"ti ti-home-check text-2xl\" data-kid=\"140\"></i>\n              </div>\n              <div data-kid=\"141\">\n                <h4 class=\"font-bold text-lg mb-1\" data-kid=\"142\">Atendimento Domiciliar</h4>\n                <p class=\"text-sm text-[var(--gray-600)]\" data-kid=\"143\">Processo ágil e silencioso no conforto da sua residência.</p>\n              </div>\n            </div>\n            <div class=\"flex items-start gap-5 p-6 bg-white rounded-2xl border border-gray-100 shadow-sm\" data-kid=\"144\">\n              <div class=\"w-12 h-12 bg-yellow-50 text-[var(--gold-600)] rounded-xl flex items-center justify-center shrink-0\" data-kid=\"145\">\n                <i class=\"ti ti-leaf text-2xl\" data-kid=\"146\"></i>\n              </div>\n              <div data-kid=\"147\">\n                <h4 class=\"font-bold text-lg mb-1\" data-kid=\"148\">Produtos Eco-Safe</h4>\n                <p class=\"text-sm text-[var(--gray-600)]\" data-kid=\"149\">Biodegradáveis e seguros para crianças e pets.</p>\n              </div>\n            </div>\n          </div>\n          <button class=\"btn-primary py-5 px-10 text-lg\" data-kid=\"150\">Nossa Tecnologia</button>\n        </div>\n      </div>\n    </div>\n  </section>\n\n  <div class=\"divider-line\" data-kid=\"151\"></div>\n\n  \n  <section id=\"orcamento\" class=\"section-padding bg-white\" data-kid=\"152\">\n    <div class=\"container max-w-5xl\" data-kid=\"153\">\n      <div class=\"text-center mb-16\" data-kid=\"154\">\n        <span class=\"section-eyebrow\" data-kid=\"155\">Calculadora Premium</span>\n        <h2 class=\"section-title\" data-kid=\"156\">Quanto Custa seu Bem-Estar?</h2>\n        <p class=\"text-[var(--gray-600)]\" data-kid=\"157\">Selecione os itens para uma estimativa instantânea.</p>\n      </div>\n\n      <div class=\"bg-white rounded-[40px] shadow-2xl border border-gray-100 overflow-hidden flex flex-col md:flex-row\" data-kid=\"158\">\n        <div class=\"md:w-3/5 p-8 md:p-12 border-r border-gray-100\" data-kid=\"159\">\n          <h3 class=\"text-xl font-black mb-8 flex items-center gap-3\" data-kid=\"160\">\n            <i class=\"ti ti-checklist text-[var(--brand-blue)]\" data-kid=\"161\"></i> Escolha os itens:\n          </h3>\n          <div class=\"space-y-4\" data-kid=\"162\">\n            <div class=\"calculator-input-row\" data-kid=\"163\">\n              <p class=\"font-bold text-[var(--gray-900)]\" data-kid=\"164\">Sofá (por assento)</p>\n              <div class=\"flex items-center gap-5\" data-kid=\"165\">\n                <button class=\"w-10 h-10 rounded-full bg-white border border-gray-200 flex items-center justify-center text-gray-400 hover:border-[var(--brand-blue)] hover:text-[var(--brand-blue)] transition-all\" data-kid=\"166\">\n                  <i class=\"ti ti-minus\" data-kid=\"167\"></i>\n                </button>\n                <span class=\"text-xl font-black w-6 text-center\" data-kid=\"168\">3</span>\n                <button class=\"w-10 h-10 rounded-full bg-white border border-gray-200 flex items-center justify-center text-gray-400 hover:border-[var(--brand-blue)] hover:text-[var(--brand-blue)] transition-all\" data-kid=\"169\">\n                  <i class=\"ti ti-plus\" data-kid=\"170\"></i>\n                </button>\n              </div>\n            </div>\n            <div class=\"calculator-input-row\" data-kid=\"171\">\n              <p class=\"font-bold text-[var(--gray-900)]\" data-kid=\"172\">Colchão de Casal</p>\n              <div class=\"flex items-center gap-5\" data-kid=\"173\">\n                <button class=\"w-10 h-10 rounded-full bg-white border border-gray-200 flex items-center justify-center text-gray-400\" data-kid=\"174\"><i class=\"ti ti-minus\" data-kid=\"175\"></i></button>\n                <span class=\"text-xl font-black w-6 text-center\" data-kid=\"176\">1</span>\n                <button class=\"w-10 h-10 rounded-full bg-white border border-gray-200 flex items-center justify-center text-gray-400\" data-kid=\"177\"><i class=\"ti ti-plus\" data-kid=\"178\"></i></button>\n              </div>\n            </div>\n            <div class=\"calculator-input-row\" data-kid=\"179\">\n              <p class=\"font-bold text-[var(--gray-900)]\" data-kid=\"180\">Tapete (por m²)</p>\n              <div class=\"flex items-center gap-5\" data-kid=\"181\">\n                <button class=\"w-10 h-10 rounded-full bg-white border border-gray-200 flex items-center justify-center text-gray-400\" data-kid=\"182\"><i class=\"ti ti-minus\" data-kid=\"183\"></i></button>\n                <span class=\"text-xl font-black w-6 text-center\" data-kid=\"184\">6</span>\n                <button class=\"w-10 h-10 rounded-full bg-white border border-gray-200 flex items-center justify-center text-gray-400\" data-kid=\"185\"><i class=\"ti ti-plus\" data-kid=\"186\"></i></button>\n              </div>\n            </div>\n          </div>\n        </div>\n        <div class=\"md:w-2/5 bg-[var(--gray-900)] p-8 md:p-12 text-white flex flex-col justify-between\" data-kid=\"187\">\n          <div data-kid=\"188\">\n            <h3 class=\"text-xl font-black mb-10 opacity-60\" data-kid=\"189\">Resumo</h3>\n            <div class=\"space-y-6\" data-kid=\"190\">\n              <div class=\"flex justify-between items-center text-sm\" data-kid=\"191\">\n                <span class=\"opacity-60\" data-kid=\"192\">Subtotal</span>\n                <span class=\"font-bold\" data-kid=\"193\">R$ 580,00</span>\n              </div>\n              <div class=\"flex justify-between items-center text-sm text-[var(--brand-gold)]\" data-kid=\"194\">\n                <span class=\"opacity-60\" data-kid=\"195\">Bônus Online</span>\n                <span class=\"font-bold\" data-kid=\"196\">- R$ 58,00</span>\n              </div>\n              <div class=\"h-px bg-white/10 my-4\" data-kid=\"197\"></div>\n              <div class=\"flex items-end gap-2\" data-kid=\"198\">\n                <span class=\"text-4xl md:text-5xl font-black text-[var(--brand-gold)] font-heading\" data-kid=\"199\">R$ 522,00</span>\n              </div>\n            </div>\n          </div>\n          <button class=\"btn-gold w-full py-5 text-lg mt-12\" data-kid=\"200\">Confirmar Agendamento <i class=\"ti ti-calendar-event\" data-kid=\"201\"></i></button>\n        </div>\n      </div>\n    </div>\n  </section>\n\n  \n  <section id=\"contato\" class=\"section-padding bg-white\" data-kid=\"202\">\n    <div class=\"container\" data-kid=\"203\">\n      <div class=\"grid md:grid-cols-2 gap-20\" data-kid=\"204\">\n        <div data-kid=\"205\">\n          <span class=\"section-eyebrow\" data-kid=\"206\">Contato</span>\n          <h2 class=\"section-title\" data-kid=\"207\">Estamos Próximos de Você</h2>\n          <div class=\"space-y-8 mt-12\" data-kid=\"208\">\n            <div class=\"flex gap-6\" data-kid=\"209\">\n              <div class=\"w-14 h-14 bg-[var(--blue-50)] text-[var(--brand-blue)] rounded-2xl flex items-center justify-center shrink-0 border border-[var(--blue-100)]\" data-kid=\"210\">\n                <i class=\"ti ti-map-pin-2 text-2xl\" data-kid=\"211\"></i>\n              </div>\n              <div data-kid=\"212\">\n                <p class=\"text-xs font-black text-gray-400 uppercase tracking-widest mb-1\" data-kid=\"213\">Localização</p>\n                <p class=\"text-[var(--gray-900)] font-bold\" data-kid=\"214\">Av. Paulista, 1000 - Bela Vista, SP</p>\n              </div>\n            </div>\n            <div class=\"flex gap-6\" data-kid=\"215\">\n              <div class=\"w-14 h-14 bg-green-50 text-green-600 rounded-2xl flex items-center justify-center shrink-0 border border-green-100\" data-kid=\"216\">\n                <i class=\"ti ti-brand-whatsapp text-2xl\" data-kid=\"217\"></i>\n              </div>\n              <div data-kid=\"218\">\n                <p class=\"text-xs font-black text-gray-400 uppercase tracking-widest mb-1\" data-kid=\"219\">WhatsApp Plantão</p>\n                <p class=\"text-[var(--gray-900)] font-bold text-xl\" data-kid=\"220\">(11) 98888-7777</p>\n              </div>\n            </div>\n          </div>\n        </div>\n        <div class=\"h-full min-h-[500px] rounded-[32px] overflow-hidden border-8 border-white shadow-xl map-container flex items-center justify-center\" data-kid=\"221\">\n          <div class=\"text-center p-12\" data-kid=\"222\">\n            <i class=\"ti ti-map-2 text-4xl text-[var(--brand-blue)] mb-4\" data-kid=\"223\"></i>\n            <h4 class=\"text-xl font-black mb-2\" data-kid=\"224\">Mapa de Cobertura</h4>\n            <p class=\"text-sm text-gray-500 mb-6\" data-kid=\"225\">Atendemos toda a região metropolitana.</p>\n            <button class=\"bg-[var(--gray-900)] text-white px-8 py-3 rounded-xl font-bold text-sm\" data-kid=\"226\">Ver Área no Google Maps</button>\n          </div>\n        </div>\n      </div>\n    </div>\n  </section>\n\n  \n  <footer class=\"bg-[var(--gray-900)] text-white pt-20 pb-10\" data-kid=\"227\">\n    <div class=\"container\" data-kid=\"228\">\n      <div class=\"grid grid-cols-1 md:grid-cols-4 gap-12 mb-16\" data-kid=\"229\">\n        <div class=\"col-span-1 md:col-span-1\" data-kid=\"230\">\n          <div class=\"flex items-center gap-3 mb-6\" data-kid=\"231\">\n            <div class=\"w-8 h-8 bg-[var(--brand-blue)] rounded-lg flex items-center justify-center text-white\" data-kid=\"232\"><i class=\"ti ti-sparkles\" data-kid=\"233\"></i></div>\n            <span class=\"text-xl font-black tracking-tight\" data-kid=\"234\">MasterClean</span>\n          </div>\n          <p class=\"text-white/40 text-sm\" data-kid=\"235\">Líder em higienização profissional de estofados.</p>\n        </div>\n        <div data-kid=\"236\">\n          <h4 class=\"font-bold mb-6\" data-kid=\"237\">Serviços</h4>\n          <ul class=\"space-y-3 text-white/50 text-sm\" data-kid=\"238\">\n            <li data-kid=\"239\">Sofás</li><li data-kid=\"240\">Tapetes</li><li data-kid=\"241\">Automotivo</li><li data-kid=\"242\">Colchões</li>\n          </ul>\n        </div>\n        <div data-kid=\"243\">\n          <h4 class=\"font-bold mb-6\" data-kid=\"244\">Institucional</h4>\n          <ul class=\"space-y-3 text-white/50 text-sm\" data-kid=\"245\">\n            <li data-kid=\"246\">Sobre</li><li data-kid=\"247\">Privacidade</li><li data-kid=\"248\">Termos</li><li data-kid=\"249\">Contato</li>\n          </ul>\n        </div>\n        <div data-kid=\"250\">\n          <h4 class=\"font-bold mb-6\" data-kid=\"251\">Novidades</h4>\n          <div class=\"relative\" data-kid=\"252\">\n            <input type=\"email\" placeholder=\"E-mail\" class=\"w-full bg-white/5 border border-white/10 rounded-xl py-3 px-4 text-sm focus:outline-none focus:border-[var(--brand-blue)] transition-colors\" data-kid=\"253\">\n          </div>\n        </div>\n      </div>\n      <div class=\"h-px bg-white/5 mb-8\" data-kid=\"254\"></div>\n      <div class=\"flex justify-between items-center text-white/20 text-[10px] font-bold tracking-widest uppercase\" data-kid=\"255\">\n        <p data-kid=\"256\">© 2024 MasterClean</p>\n        <p data-kid=\"257\">Toque de Luxo</p>\n      </div>\n    </div>\n  </footer>\n</div>\n",
