      "html": "\n<style data-kid=\"0\">\n  @import url('https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&family=Outfit:wght@300;400;500;600;700;800;900&display=swap');\n  @import url('https://cdn.jsdelivr.net/npm/@tabler/icons-webfont/tabler-icons.min.css');\n\n  :root {\n    --white: #ffffff;\n    --off-white: #f8faff;\n    --gray-50: #f1f5fb;\n    --gray-100: #e4ecf7;\n    --gray-200: #c8d9ef;\n    --gray-400: #8fa3c0;\n    --gray-600: #4a6080;\n    --gray-800: #1e3050;\n    --gray-900: #0d1f38;\n    --blue-50: #eef4ff;\n    --blue-100: #dce9ff;\n    --blue-300: #6fa3f5;\n    --blue-500: #1a6ef5;\n    --blue-600: #0f59d4;\n    --blue-700: #0a46b0;\n    --blue-800: #063490;\n    --blue-900: #042470;\n    --gold-100: #fff8e1;\n    --gold-300: #fdd36a;\n    --gold-400: #eab308;\n    --gold-500: #e8a800;\n    --gold-600: #c98900;\n    --bg-page: var(--white);\n    --bg-section: var(--off-white);\n    --bg-accent: var(--blue-50);\n    --bg-hero: var(--blue-900);\n    --text-primary: var(--gray-900);\n    --text-secondary: var(--gray-600);\n    --text-muted: var(--gray-400);\n    --text-on-dark: var(--white);\n    --brand-blue: var(--blue-600);\n    --brand-gold: var(--gold-400);\n    --brand-hover: var(--blue-700);\n    --font-sans: 'Inter', sans-serif;\n    --font-heading: 'Outfit', sans-serif;\n    --shadow-xs: 0 1px 3px rgba(13, 31, 56, 0.08);\n    --shadow-sm: 0 2px 8px rgba(13, 31, 56, 0.10);\n    --shadow-md: 0 6px 24px rgba(13, 31, 56, 0.12);\n    --shadow-lg: 0 16px 48px rgba(13, 31, 56, 0.15);\n    --shadow-xl: 0 24px 64px rgba(13, 31, 56, 0.20);\n    --shadow-blue: 0 4px 20px rgba(26, 110, 245, 0.30);\n    --shadow-gold: 0 4px 20px rgba(234, 179, 8, 0.35);\n    --transition-fast: all 0.18s ease;\n    --transition-normal: all 0.28s ease;\n    --transition-slow: all 0.45s ease;\n    --radius-sm: 8px;\n    --radius-md: 14px;\n    --radius-lg: 20px;\n    --radius-xl: 28px;\n    --radius-pill: 999px;\n  }\n\n  body {\n    font-family: var(--font-sans);\n    background-color: var(--bg-page);\n    color: var(--text-primary);\n    line-height: 1.65;\n    -webkit-font-smoothing: antialiased;\n  }\n\n  h1, h2, h3, h4, h5, h6 {\n    font-family: var(--font-heading);\n    font-weight: 700;\n    line-height: 1.2;\n    color: var(--text-primary);\n  }\n\n  .container {\n    max-width: 1200px;\n    margin: 0 auto;\n    padding: 0 24px;\n    position: relative;\n    z-index: 2;\n  }\n\n  .section-padding { padding: 100px 0; }\n  .section-eyebrow {\n    display: inline-block;\n    font-family: var(--font-heading);\n    font-size: 0.75rem;\n    font-weight: 800;\n    text-transform: uppercase;\n    letter-spacing: 2px;\n    color: var(--brand-blue);\n    background: var(--blue-50);\n    border: 1px solid var(--blue-100);\n    padding: 6px 16px;\n    border-radius: var(--radius-pill);\n    margin-bottom: 20px;\n  }\n  .section-title {\n    font-size: 3rem;\n    font-weight: 900;\n    color: var(--text-primary);\n    margin-bottom: 24px;\n    letter-spacing: -1px;\n  }\n  .section-title span.gold { color: var(--brand-gold); }\n  .section-subtitle {\n    font-size: 1.125rem;\n    color: var(--text-secondary);\n    max-width: 600px;\n    margin-bottom: 60px;\n  }\n  .section-header-center {\n    text-align: center;\n    display: flex;\n    flex-direction: column;\n    align-items: center;\n  }\n  .section-title-underline {\n    width: 64px;\n    height: 4px;\n    border-radius: 2px;\n    background: linear-gradient(90deg, var(--brand-gold) 0%, var(--gold-300) 100%);\n    margin: 16px auto 0;\n  }\n  .card {\n    background: var(--white);\n    border-radius: var(--radius-lg);\n    border: 1px solid var(--gray-100);\n    box-shadow: var(--shadow-sm);\n    transition: var(--transition-normal);\n  }\n  .card:hover {\n    box-shadow: var(--shadow-md);\n    transform: translateY(-4px);\n    border-color: var(--blue-100);\n  }\n  .btn-primary {\n    display: inline-flex;\n    align-items: center;\n    gap: 12px;\n    background: linear-gradient(135deg, var(--blue-600) 0%, var(--blue-800) 100%);\n    color: var(--white);\n    padding: 16px 36px;\n    font-size: 1rem;\n    font-weight: 700;\n    border-radius: var(--radius-pill);\n    transition: var(--transition-normal);\n    box-shadow: var(--shadow-blue);\n    font-family: var(--font-heading);\n    cursor: pointer;\n  }\n  .btn-primary:hover {\n    transform: translateY(-2px);\n    box-shadow: 0 10px 30px rgba(26, 110, 245, 0.4);\n    filter: brightness(1.1);\n  }\n  .btn-gold {\n    display: inline-flex;\n    align-items: center;\n    gap: 12px;\n    background: linear-gradient(135deg, var(--gold-400) 0%, var(--gold-500) 100%);\n    color: var(--gray-900);\n    padding: 16px 36px;\n    font-size: 1rem;\n    font-weight: 700;\n    border-radius: var(--radius-pill);\n    transition: var(--transition-normal);\n    box-shadow: var(--shadow-gold);\n    font-family: var(--font-heading);\n    cursor: pointer;\n  }\n  .btn-gold:hover {\n    transform: translateY(-2px);\n    box-shadow: 0 10px 30px rgba(234, 179, 8, 0.4);\n    filter: brightness(1.05);\n  }\n  .btn-outline {\n    display: inline-flex;\n    align-items: center;\n    gap: 12px;\n    padding: 14px 32px;\n    font-size: 1rem;\n    font-weight: 700;\n    border: 2px solid var(--blue-100);\n    border-radius: var(--radius-pill);\n    transition: var(--transition-normal);\n    color: var(--brand-blue);\n    font-family: var(--font-heading);\n    cursor: pointer;\n  }\n  .btn-outline:hover {\n    border-color: var(--brand-blue);\n    background: var(--blue-50);\n  }\n  .icon-circle {\n    width: 60px;\n    height: 60px;\n    border-radius: 50%;\n    display: flex;\n    align-items: center;\n    justify-content: center;\n    flex-shrink: 0;\n  }\n  .icon-circle.blue { background: var(--blue-50); color: var(--brand-blue); border: 1px solid var(--blue-100); }\n  .icon-circle.gold { background: var(--gold-100); color: var(--gold-600); border: 1px solid rgba(234, 179, 8, 0.2); }\n  .check-badge {\n    width: 24px;\n    height: 24px;\n    border-radius: 50%;\n    background: var(--gold-100);\n    color: var(--gold-600);\n    display: flex;\n    align-items: center;\n    justify-content: center;\n    font-size: 0.8rem;\n  }\n\n  /* Custom Styles */\n  .grid-pattern {\n    background-image: radial-gradient(var(--gray-200) 0.5px, transparent 0.5px);\n    background-size: 24px 24px;\n  }\n  \n  .floating-img {\n    animation: floating 6s ease-in-out infinite;\n  }\n  @keyframes floating {\n    0%, 100% { transform: translateY(0); }\n    50% { transform: translateY(-20px); }\n  }\n\n  .nav-fixed {\n    position: absolute; /* Using absolute inside iframe context as per constraints */\n    top: 0;\n    left: 0;\n    width: 100%;\n    z-index: 50;\n    background: rgba(255, 255, 255, 0.9);\n    backdrop-filter: blur(10px);\n    border-bottom: 1px solid var(--gray-100);\n  }\n\n  .before-after-handle {\n    left: 50%;\n    transform: translateX(-50%);\n  }\n\n  .step-active { background: var(--brand-blue); color: white; }\n  .step-inactive { background: var(--gray-100); color: var(--gray-400); }\n</style>\n\n<div class=\"relative min-h-screen\" data-kid=\"1\">\n  \n  <nav class=\"nav-fixed py-6\" data-kid=\"2\">\n    <div class=\"container flex justify-between items-center\" data-kid=\"3\">\n      <div class=\"flex items-center gap-2\" data-kid=\"4\">\n        <div class=\"w-10 h-10 bg-[var(--brand-blue)] rounded-xl flex items-center justify-center text-white\" data-kid=\"5\">\n          <i class=\"ti ti-sparkles text-2xl\" data-kid=\"6\"></i>\n        </div>\n        <span class=\"text-2xl font-black tracking-tighter text-[var(--gray-900)]\" data-kid=\"7\">Master<span class=\"text-[var(--brand-gold)]\" data-kid=\"8\">Clean</span></span>\n      </div>\n      <div class=\"hidden md:flex items-center gap-10 font-bold text-sm text-[var(--gray-600)] uppercase tracking-widest\" data-kid=\"9\">\n        <a href=\"#\" class=\"hover:text-[var(--brand-blue)] transition-colors\" data-kid=\"10\">Serviços</a>\n        <a href=\"#\" class=\"hover:text-[var(--brand-blue)] transition-colors\" data-kid=\"11\">Resultados</a>\n        <a href=\"#\" class=\"hover:text-[var(--brand-blue)] transition-colors\" data-kid=\"12\">Preços</a>\n        <a href=\"#\" class=\"hover:text-[var(--brand-blue)] transition-colors\" data-kid=\"13\">Contato</a>\n      </div>\n      <button class=\"btn-primary py-3 px-8 text-sm\" data-kid=\"14\">\n        <i class=\"ti ti-calendar\" data-kid=\"15\"></i>\n        Agendar\n      </button>\n    </div>\n  </nav>\n\n  \n  <header class=\"relative pt-48 pb-32 overflow-hidden bg-white\" data-kid=\"16\">\n    <div class=\"absolute top-0 right-0 w-1/3 h-full bg-[var(--blue-50)] -skew-x-12 translate-x-1/2 -z-10\" data-kid=\"17\"></div>\n    <div class=\"container grid lg:grid-cols-2 gap-20 items-center\" data-kid=\"18\">\n      <div class=\"relative\" data-kid=\"19\">\n        \n        <div class=\"absolute -top-24 -left-24 w-64 h-64 grid-pattern opacity-40 pointer-events-none\" data-kid=\"20\"></div>\n        \n        <div class=\"pl-10 border-l-[6px] border-[var(--brand-gold)] relative z-10\" data-kid=\"21\">\n          <span class=\"section-eyebrow\" data-kid=\"22\">Precisão em cada detalhe</span>\n          <h1 class=\"text-7xl font-black leading-[1.1] mb-8 text-[var(--gray-900)]\" data-kid=\"23\">\n            Limpeza <span class=\"text-[var(--brand-blue)]\" data-kid=\"24\">Profunda</span> para seu <span class=\"whitespace-nowrap\" data-kid=\"25\">Bem-estar.</span>\n          </h1>\n          <p class=\"text-xl text-[var(--text-secondary)] mb-12 max-w-xl leading-relaxed\" data-kid=\"26\">\n            Especialistas em higienização de estofados e detalhamento automotivo com tecnologia de extração minimalista e proteção health+.\n          </p>\n          <div class=\"flex flex-wrap gap-6\" data-kid=\"27\">\n            <button class=\"btn-primary py-5\" data-kid=\"28\">\n              <i class=\"ti ti-brand-whatsapp text-xl\" data-kid=\"29\"></i>\n              Orçamento Via WhatsApp\n            </button>\n            <div class=\"flex items-center gap-4\" data-kid=\"30\">\n              <div class=\"flex -space-x-3\" data-kid=\"31\">\n                <img src=\"https://i.pravatar.cc/100?u=1\" class=\"w-10 h-10 rounded-full border-2 border-white\" alt=\"Client\" data-kid=\"32\">\n                <img src=\"https://i.pravatar.cc/100?u=2\" class=\"w-10 h-10 rounded-full border-2 border-white\" alt=\"Client\" data-kid=\"33\">\n                <img src=\"https://i.pravatar.cc/100?u=3\" class=\"w-10 h-10 rounded-full border-2 border-white\" alt=\"Client\" data-kid=\"34\">\n              </div>\n              <p class=\"text-sm font-bold text-[var(--gray-900)]\" data-kid=\"35\">+2k Avaliações 5★</p>\n            </div>\n          </div>\n        </div>\n\n        \n        <div class=\"mt-20 grid grid-cols-3 gap-8 max-w-lg\" data-kid=\"36\">\n          <div class=\"flex flex-col gap-2\" data-kid=\"37\">\n            <span class=\"text-3xl font-black text-[var(--gray-900)]\" data-kid=\"38\">99%</span>\n            <div class=\"w-12 h-1 bg-[var(--brand-blue)] rounded-full\" data-kid=\"39\"></div>\n            <p class=\"text-xs uppercase font-bold tracking-widest text-[var(--text-muted)]\" data-kid=\"40\">Satisfação</p>\n          </div>\n          <div class=\"flex flex-col gap-2\" data-kid=\"41\">\n            <span class=\"text-3xl font-black text-[var(--gray-900)]\" data-kid=\"42\">15+</span>\n            <div class=\"w-12 h-1 bg-[var(--brand-gold)] rounded-full\" data-kid=\"43\"></div>\n            <p class=\"text-xs uppercase font-bold tracking-widest text-[var(--text-muted)]\" data-kid=\"44\">Cidades</p>\n          </div>\n          <div class=\"flex flex-col gap-2\" data-kid=\"45\">\n            <span class=\"text-3xl font-black text-[var(--gray-900)]\" data-kid=\"46\">24h</span>\n            <div class=\"w-12 h-1 bg-[var(--brand-blue)] rounded-full\" data-kid=\"47\"></div>