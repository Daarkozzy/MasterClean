      "html": "\n<style data-kid=\"0\">\n  @import url('https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&family=Outfit:wght@300;400;500;600;700;800;900&display=swap');\n\n  :root {\n    --navy: #1e293b;\n    --gold: #eab308;\n    --gold-light: #fef08a;\n    --gold-dark: #ca8a04;\n    \n    --white: #ffffff;\n    --off-white: #f8faff;\n    \n    --font-sans: 'Inter', sans-serif;\n    --font-heading: 'Outfit', sans-serif;\n\n    --shadow-soft: 0 10px 30px -5px rgba(30, 41, 59, 0.08);\n    --shadow-card: 0 20px 40px -10px rgba(30, 41, 59, 0.12);\n  }\n\n  body {\n    font-family: var(--font-sans);\n    color: var(--navy);\n    background-color: var(--white);\n    margin: 0;\n  }\n\n  h1, h2, h3, h4, h5, h6 {\n    font-family: var(--font-heading);\n  }\n\n  .btn-gold {\n    background: linear-gradient(to bottom right, #facc15, #eab308, #ca8a04);\n    transition: all 0.4s cubic-bezier(0.23, 1, 0.32, 1);\n    box-shadow: 0 4px 0px rgba(161, 98, 7, 0.4), 0 10px 20px -5px rgba(234, 179, 8, 0.3);\n    border: 1px solid rgba(255, 255, 255, 0.4);\n    position: relative;\n    overflow: hidden;\n  }\n\n  .btn-gold:hover {\n    transform: translateY(-2px);\n    box-shadow: 0 6px 0px rgba(161, 98, 7, 0.4), 0 15px 30px -5px rgba(234, 179, 8, 0.5);\n    filter: brightness(1.05);\n  }\n\n  .btn-gold:active {\n    transform: translateY(2px);\n    box-shadow: 0 2px 0px rgba(161, 98, 7, 0.4), 0 5px 10px -2px rgba(234, 179, 8, 0.3);\n  }\n\n  .service-card {\n    transition: all 0.5s cubic-bezier(0.23, 1, 0.32, 1);\n    border: 1px solid rgba(30, 41, 59, 0.04);\n    box-shadow: 0 10px 40px -10px rgba(30, 41, 59, 0.03);\n  }\n\n  .service-card:hover {\n    transform: translateY(-12px);\n    box-shadow: 0 30px 60px -15px rgba(30, 41, 59, 0.12);\n    border-color: rgba(234, 179, 8, 0.2);\n  }\n\n  .glass-card {\n    background: rgba(255, 255, 255, 0.9);\n    backdrop-filter: blur(10px);\n    border: 1px solid rgba(255, 255, 255, 0.2);\n  }\n\n  .hero-blob {\n    position: absolute;\n    z-index: -1;\n    filter: blur(80px);\n    opacity: 0.15;\n    background: var(--gold);\n    border-radius: 50%;\n  }\n\n  /* Custom tabs styling */\n  .tab-active {\n    background: var(--navy);\n    color: white;\n  }\n\n  .tab-inactive {\n    background: var(--off-white);\n    color: var(--navy);\n  }\n\n  /* Subtle lighting for hero */\n  .hero-light-effect {\n    background: radial-gradient(circle at center, var(--gold) 0%, transparent 70%);\n    filter: blur(100px);\n    opacity: 0.12;\n  }\n</style>\n\n<div class=\"min-h-full flex flex-col\" data-kid=\"1\">\n  \n  <nav class=\"relative z-50 bg-white border-b border-gray-50\" data-kid=\"2\">\n    <div class=\"max-w-7xl mx-auto px-4 sm:px-6 lg:px-8\" data-kid=\"3\">\n      <div class=\"flex justify-between items-center h-24\" data-kid=\"4\">\n        <div class=\"flex items-center gap-3 group cursor-pointer\" data-kid=\"5\">\n          <div class=\"w-12 h-12 bg-[var(--navy)] rounded-xl flex items-center justify-center transition-transform group-hover:scale-110\" data-kid=\"6\">\n            <span class=\"text-[var(--gold)] font-black text-2xl italic\" data-kid=\"7\">M</span>\n          </div>\n          <div class=\"flex flex-col -gap-0.5\" data-kid=\"8\">\n            <span class=\"text-2xl font-black font-[var(--font-heading)] tracking-tight text-[var(--navy)] leading-none\" data-kid=\"9\">\n              MASTER<span class=\"text-[var(--gold)]\" data-kid=\"10\">CLEAN</span>\n            </span>\n            <span class=\"text-[10px] font-bold tracking-[0.25em] text-gray-300 uppercase\" data-kid=\"11\">Refino Profissional</span>\n          </div>\n        </div>\n        <div class=\"hidden md:flex items-center gap-10\" data-kid=\"12\">\n          <div class=\"flex items-center gap-12\" data-kid=\"13\">\n            <a href=\"#services\" class=\"text-xs font-black uppercase tracking-[0.2em] text-[var(--navy)] hover:text-[var(--gold)] transition-colors relative group\" data-kid=\"14\">\n   