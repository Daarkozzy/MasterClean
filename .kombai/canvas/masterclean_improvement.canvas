d-full border border-white/10 flex items-center justify-center text-white hover:bg-white hover:text-[var(--blue-900)] transition-all\" data-kid=\"307\">\n              <i class=\"ti ti-brand-instagram text-xl\" data-kid=\"308\"></i>\n            </a>\n            <a href=\"#\" class=\"w-12 h-12 rounded-full border border-white/10 flex items-center justify-center text-white hover:bg-white hover:text-[var(--blue-900)] transition-all\" data-kid=\"309\">\n              <i class=\"ti ti-brand-facebook text-xl\" data-kid=\"310\"></i>\n            </a>\n            <a href=\"#\" class=\"w-12 h-12 rounded-full border border-white/10 flex items-center justify-center text-white hover:bg-white hover:text-[var(--blue-900)] transition-all\" data-kid=\"311\">\n              <i class=\"ti ti-brand-linkedin text-xl\" data-kid=\"312\"></i>\n            </a>\n            <a href=\"#\" class=\"w-12 h-12 rounded-full border border-white/10 flex items-center justify-center text-white hover:bg-white hover:text-[var(--blue-900)] transition-all\" data-kid=\"313\">\n              <i class=\"ti ti-brand-youtube text-xl\" data-kid=\"314\"></i>\n            </a>\n          </div>\n        </div>\n\n        \n        <div class=\"grid grid-cols-2 sm:grid-cols-3 gap-16 flex-1\" data-kid=\"315\">\n          <div data-kid=\"316\">\n            <h4 class=\"font-heading font-black text-white text-lg mb-8 uppercase tracking-widest\" data-kid=\"317\">Serviços</h4>\n            <ul class=\"space-y-4\" data-kid=\"318\">\n              <li data-kid=\"319\"><a href=\"#\" class=\"text-[var(--gray-400)] hover:text-white transition-colors font-bold\" data-kid=\"320\">Limpeza de Sofá</a></li>\n              <li data-kid=\"321\"><a href=\"#\" class=\"text-[var(--gray-400)] hover:text-white transition-colors font-bold\" data-kid=\"322\">Higienização Veicular</a></li>\n              <li data-kid=\"323\"><a href=\"#\" class=\"text-[var(--gray-400)] hover:text-white transition-colors font-bold\" data-kid=\"324\">Limpeza de Colchão</a></li>\n              <li data-kid=\"325\"><a href=\"#\" class=\"text-[var(--gray-400)] hover:text-white transition-colors font-bold\" data-kid=\"326\">Tapetes & Carpetes</a></li>\n              <li data-kid=\"327\"><a href=\"#\" class=\"text-[var(--gray-400)] hover:text-white transition-colors font-bold\" data-kid=\"328\">Impermeabilização</a></li>\n            </ul>\n          </div>\n          <div data-kid=\"329\">\n            <h4 class=\"font-heading font-black text-white text-lg mb-8 uppercase tracking-widest\" data-kid=\"330\">Empresa</h4>\n            <ul class=\"space-y-4\" data-kid=\"331\">\n              <li data-kid=\"332\"><a href=\"#\" class=\"text-[var(--gray-400)] hover:text-white transition-colors font-bold\" data-kid=\"333\">Sobre Nós</a></li>\n              <li data-kid=\"334\"><a href=\"#\" class=\"text-[var(--gray-400)] hover:text-white transition-colors font-bold\" data-kid=\"335\">Nossa Tecnologia</a></li>\n              <li data-kid=\"336\"><a href=\"#\" class=\"text-[var(--gray-400)] hover:text-white transition-colors font-bold\" data-kid=\"337\">Trabalhe Conosco</a></li>\n              <li data-kid=\"338\"><a href=\"#\" class=\"text-[var(--gray-400)] hover:text-white transition-colors font-bold\" data-kid=\"339\">Seja um Franqueado</a></li>\n              <li data-kid=\"340\"><a href=\"#\" class=\"text-[var(--gray-400)] hover:text-white transition-colors font-bold\" data-kid=\"341\">Blog da Limpeza</a></li>\n            </ul>\n          </div>\n          <div class=\"col-span-2 sm:col-span-1\" data-kid=\"342\">\n            <h4 class=\"font-heading font-black text-white text-lg mb-8 uppercase tracking-widest\" data-kid=\"343\">Newsletter</h4>\n            <p class=\"text-[var(--gray-400)] text-sm mb-6\" data-kid=\"344\">Receba dicas de conservação e ofertas exclusivas.</p>\n            <div class=\"relative\" data-kid=\"345\">\n              <input type=\"email\" placeholder=\"Seu e-mail...\" class=\"w-full bg-white/5 border border-white/10 rounded-xl px-6 py-4 text-white focus:outline-none focus:border-[var(--gold-400)] transition-colors\" data-kid=\"346\">\n              <button class=\"absolute right-2 top-2 bottom-2 bg-[var(--gold-400)] text-[var(--gray-900)] px-4 rounded-lg font-bold\" data-kid=\"347\">\n                <i class=\"ti ti-send\" data-kid=\"348\"></i>\n              </button>\n            </div>\n          </div>\n        </div>\n      </div>\n\n      \n      <div class=\"pt-10 border-t border-white/10 flex flex-col md:flex-row justify-between items-center gap-6 text-[var(--gray-600)] font-bold text-sm\" data-kid=\"349\">\n        <p data-kid=\"350\">© 2024 MasterClean Higienização. Todos os direitos reservados.</p>\n        <div class=\"flex items-center gap-8\" data-kid=\"351\">\n          <a href=\"#\" class=\"hover:text-white transition-colors\" data-kid=\"352\">Políticas de Privacidade</a>\n          <a href=\"#\" class=\"hover:text-white transition-colors\" data-kid=\"353\">Termos de Uso</a>\n          <a href=\"#\" class=\"hover:text-white transition-colors\" data-kid=\"354\">Cookies</a>\n        </div>\n      </div>\n    </div>\n  </footer>\n</div>\n",
