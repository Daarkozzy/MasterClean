      "html": "\n<style data-kid=\"0\">\n  @import url('https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&family=Outfit:wght@300;400;500;600;700;800;900&display=swap');\n  @import url('https://cdn.jsdelivr.net/npm/@tabler/icons-webfont/tabler-icons.min.css');\n\n  :root {\n    --white: #ffffff;\n    --off-white: #f8faff;\n    --gray-50: #f1f5fb;\n    --gray-100: #e4ecf7;\n    --gray-200: #c8d9ef;\n    --gray-400: #8fa3c0;\n    --gray-600: #4a6080;\n    --gray-800: #1e3050;\n    --gray-900: #0d1f38;\n    --blue-500: #1a6ef5;\n    --blue-600: #0f59d4;\n    --gold-400: #f9b800;\n    --gold-500: #e8a800;\n    --font-sans: 'Inter', sans-serif;\n    --font-heading: 'Outfit', sans-serif;\n  }\n\n  body {\n    font-family: var(--font-sans);\n    background-color: var(--white);\n    color: var(--gray-900);\n    margin: 0;\n  }\n\n  .bento-card {\n    border-radius: 28px;\n    border: 1px solid var(--gray-100);\n    box-shadow: 0 4px 20px rgba(13, 31, 56, 0.04);\n    transition: all 0.3s ease;\n  }\n\n  .bento-card:hover {\n    box-shadow: 0 10px 40px rgba(13, 31, 56, 0.08);\n    transform: translateY(-4px);\n  }\n\n  .btn-gradient {\n    background: linear-gradient(135deg, var(--blue-500) 0%, #0a46b0 100%);\n    box-shadow: 0 4px 20px rgba(26, 110, 245, 0.3);\n  }\n\n  .btn-gold {\n    background: linear-gradient(135deg, var(--gold-400) 0%, var(--gold-500) 100%);\n    box-shadow: 0 4px 20px rgba(249, 184, 0, 0.35);\n  }\n</style>\n\n<div class=\"w-full bg-white\" data-kid=\"1\">\n  \n  <nav class=\"relative z-50 bg-white border-b border-gray-100\" data-kid=\"2\">\n    <div class=\"max-w-[1440px] mx-auto px-8 h-20 flex items-center justify-between\" data-kid=\"3\">\n      <div class=\"flex items-center gap-2\" data-kid=\"4\">\n        <div class=\"w-10 h-10 bg-[#0d1f38] rounded-xl flex items-center justify-center text-white\" data-kid=\"5\">\n          <i class=\"ti ti-sparkles text-2xl text-[#f9b800]\" data-kid=\"6\"></i>\n        </div>\n        <span class=\"font-heading font-black text-2xl tracking-tighter text-[#0d1f38]\" data-kid=\"7\">MASTER<span class=\"text-[#1a6ef5]\" data-kid=\"8\">CLEAN</span></span>\n      </div>\n      <div class=\"hidden md:flex items-center gap-10\" data-kid=\"9\">\n        <a href=\"#\" class=\"font-semibold text-[#4a6080] hover:text-[#1a6ef5]\" data-kid=\"10\">Services</a>\n        <a href=\"#\" class=\"font-semibold text-[#4a6080] hover:text-[#1a6ef5]\" data-kid=\"11\">The Difference</a>\n        <a href=\"#\" class=\"font-semibold text-[#4a6080] hover:text-[#1a6ef5]\" data-kid=\"12\">Calculator</a>\n        <a href=\"#\" class=\"font-semibold text-[#4a6080] hover:text-[#1a6ef5]\" data-kid=\"13\">Testimonials</a>\n      </div>\n      <button class=\"bg-[#0d1f38] text-white px-6 py-2.5 rounded-full font-bold text-sm hover:bg-black transition-all\" data-kid=\"14\">\n        Book Inspection\n      </button>\n    </div>\n  </nav>\n\n  \n  <section class=\"py-16 px-8 bg-[#f8faff] relative overflow-hidden\" data-kid=\"15\">\n    <div class=\"absolute top-0 right-0 w-[800px] h-[800px] bg-blue-100/50 rounded-full blur-[150px] -mr-96 -mt-96\" data-kid=\"16\"></div>\n    <div class=\"max-w-[1440px] mx-auto\" data-kid=\"17\">\n      <div class=\"grid grid-cols-12 gap-6 h-[720px]\" data-kid=\"18\">\n        \n        <div class=\"col-span-12 lg:col-span-8 row-span-4 bento-card bg-white p-12 flex flex-col justify-center\" data-kid=\"19\">\n          <span class=\"inline-block font-heading text-[0.78rem] font-bold uppercase tracking-[2px] text-[#0f59d4] bg-[#eef4ff] border border-[#dce9ff] px-3.5 py-1 rounded-full mb-6 w-fit\" data-kid=\"20\">Curated Professionalism</span>\n          <h1 class=\"font-heading text-6xl xl:text-7xl font-extrabold text-[#0d1f38] leading-[1.05] mb-8\" data-kid=\"21\">Elevated Care for Your <span class=\"text-[#e8a800]\" data-kid=\"22\">Luxury</span> Interiors.</h1>\n          <p class=\"text-[#4a6080] text-xl max-w-[600px] mb-12 leading-relaxed\" data-kid=\"23\">Artisanal upholstery restoration using clinical-grade steam technology. We don't just clean; we rejuvenate the soul of your furniture.</p>\n          <div class=\"flex flex-wrap items-center gap-6\" data-kid=\"24\">\n            <button class=\"btn-gradient text-white px-10 py-5 rounded-full font-bold text-lg flex items-center gap-3 transition-all hover:scale-105\" data-kid=\"25\">\n              Instant Quote <i class=\"ti ti-arrow-right\" data-kid=\"26\"></i>\n            </button>\n            <div class=\"flex items-center gap-4\" data-kid=\"27\">\n              <div class=\"flex -space-x-3\" data-kid=\"28\">\n                <img src=\"https://i.pravatar.cc/100?u=1\" class=\"w-10 h-10 rounded-full border-2 border-white\" alt=\"Avatar\" data-kid=\"29\">\n                <img src=\"https://i.pravatar.cc/100?u=2\" class=\"w-10 h-10 rounded-full border-2 border-white\" alt=\"Avatar\" data-kid=\"30\">\n                <img src=\"https://i.pravatar.cc/100?u=3\" class=\"w-10 h-10 rounded-full border-2 border-white\" alt=\"Avatar\" data-kid=\"31\">\n              </div>\n              <div class=\"text-sm font-semibold text-[#4a6080]\" data-kid=\"32\">\n                Joined by <span class=\"text-[#0d1f38]\" data-kid=\"33\">5,000+</span> happy clients\n              </div>\n            </div>\n          </div>\n        </div>\n\n        \n        <div class=\"col-span-12 lg:col-span-4 row-span-4 bento-card overflow-hidden relative group border-none shadow-none\" data-kid=\"34\">\n          <video src=\"https://videos.pexels.com/video-files/4823675/4823675-uhd_2560_1440_30fps.mp4\" poster=\"https://images.pexels.com/videos/4823675/pexels-photo-4823675.jpeg?auto=compress&cs=tinysrgb&fit=crop&h=630&w=1200\" autoplay muted loop playsinline class=\"w-full h-full object-cover group-hover:scale-110 transition-transform duration-700\" data-kid=\"35\"></video>\n          <div class=\"absolute inset-0 bg-gradient-to-t from-[#0d1f38]/80 via-transparent to-transparent\" data-kid=\"36\"></div>\n          <div class=\"absolute bottom-8 left-8 flex items-center gap-4\" data-kid=\"37\">\n            <div class=\"w-14 h-14 bg-white/20 backdrop-blur-xl rounded-full flex items-center justify-center text-white text-2xl border border-white/30\" data-kid=\"38\">\n              <i class=\"ti ti-player-play-filled\" data-kid=\"39\"></i>\n            </div>\n            <div data-kid=\"40\">\n              <span class=\"block text-white font-heading font-bold text-lg leading-none mb-1\" data-kid=\"41\">Watch our craft</span>\n              <span class=\"text-white/60 text-sm\" data-kid=\"42\">Real-time deep steam process</span>\n            </div>\n          </div>\n        </div>\n\n        \n        <div class=\"col-span-12 lg:col-span-3 row-span-2 bento-card bg-white p-8 flex flex-col justify-center items-center text-center\" data-kid=\"43\">\n          <div class=\"w-14 h-14 bg-[#fff8e1] rounded-2xl flex items-center justify-center text-[#e8a800] mb-4\" data-kid=\"44\">\n            <i class=\"ti ti-star-filled text-2xl\" data-kid=\"45\"></i>\n          </div>\n          <div class=\"text-4xl font-heading font-black text-[#0d1f38] mb-1\" data-kid=\"46\">4.9/5.0</div>\n          <p class=\"text-[#8fa3c0] text-sm font-bold uppercase tracking-widest\" data-kid=\"47\">Average Rating</p>\n        </div>\n\n        \n        <div class=\"col-span-12 lg:col-span-9 row-span-2 bento-card bg-[#0d1f38] p-8 flex flex-col md:flex-row items-center justify-between border-none\" data-kid=\"48\">\n          <div class=\"mb-6 md:mb-0\" data-kid=\"49\">\n            <h4 class=\"text-white font-heading font-bold text-xl mb-1 flex items-center gap-2\" data-kid=\"50\">\n              <i class=\"ti ti-sparkles text-[#f9b800]\" data-kid=\"51\"></i>\n              Gold Standard Trust\n            </h4>\n            <p class=\"text-[#8fa3c0] text-sm\" data-kid=\"52\">Compliant with international hygiene protocols.</p>\n          </div>\n          <div class=\"flex items-center gap-12 opacity-40 grayscale hover:grayscale-0 transition-all\" data-kid=\"53\">\n            <div class=\"text-white font-heading font-black text-2xl tracking-tighter\" data-kid=\"54\">HYGIENE+</div>\n            <div class=\"text-white font-heading font-black text-2xl tracking-tighter\" data-kid=\"55\">PURECLEAN</div>\n            <div class=\"text-white font-heading font-black text-2xl tracking-tighter\" data-kid=\"56\">STAINREPEL</div>\n            <div class=\"text-white font-heading font-black text-2xl tracking-tighter\" data-kid=\"57\">ECOSMART</div>\n          </div>\n        </div>\n      </div>\n    </div>\n  </section>\n\n  \n  <section class=\"py-24 px-8\" data-kid=\"58\">\n    <div class=\"max-w-[1440px] mx-auto\" data-kid=\"59\">\n      <div class=\"flex flex-col items-center text-center mb-16\" data-kid=\"60\">\n        <span class=\"inline-block font-heading text-[0.78rem] font-bold uppercase tracking-[2px] text-[#0f59d4] bg-[#eef4ff] border border-[#dce9ff] px-3.5 py-1 rounded-full mb-4\" data-kid=\"61\">Our Expertise</span>\n        <h2 class=\"font-heading text-4xl font-extrabold text-[#0d1f38] mb-4\" data-kid=\"62\">Specialized Cleaning Solutions</h2>\n        <div class=\"w-16 h-1 bg-[#e8a800] rounded-full mb-10\" data-kid=\"63\"></div>\n        \n        <div class=\"flex bg-gray-50 p-1.5 rounded-full border border-gray-100 mb-12\" data-kid=\"64\">\n          <button class=\"px-10 py-3 bg-[#0d1f38] text-white rounded-full font-bold shadow-lg transition-all hover:scale-105\" data-kid=\"65\">Sofas</button>\n          <button class=\"px-10 py-3 text-[#4a6080] font-bold hover:text-[#0d1f38] hover:bg-white/50 rounded-full transition-all\" data-kid=\"66\">Carpets</button>\n          <button class=\"px-10 py-3 text-[#4a6080] font-bold hover:text-[#0d1f38] hover:bg-white/50 rounded-full transition-all\" data-kid=\"67\">Vehicles</button>\n          <button class=\"px-10 py-3 text-[#4a6080] font-bold hover:text-[#0d1f38] hover:bg-white/50 rounded-full transition-all\" data-kid=\"68\">Leather</button>\n        </div>\n      </div>\n\n      <div class=\"grid grid-cols-12 gap-8 h-[640px]\" data-kid=\"69\">\n        \n        <div class=\"col-span-12 lg:col-span-6 row-span-6 rounded-[32px] overflow-hidden border border-gray-100 shadow-sm relative group\" data-kid=\"70\">\n          <img src=\"https://images.unsplash.com/photo-1687634366070-c06d3f037154?auto=format&w=1200&q=80&fit=crop\" class=\"w-full h-full object-cover group-hover:scale-105 transition-transform duration-1000\" alt=\"Luxurious Interior\" data-kid=\"71\">\n          <div class=\"absolute inset-0 bg-gradient-to-t from-[#0d1f38] via-[#0d1f38]/20 to-transparent flex flex-col justify-end p-12\" data-kid=\"72\">\n            <h3 class=\"text-white font-heading text-4xl font-bold mb-3\" data-kid=\"73\">Vehicle Luxury Rejuvenation</h3>\n            <p class=\"text-gray-300 text-lg max-w-[400px]\" data-kid=\"74\">Full interior restoration with leather conditioning and deep fiber extraction.</p>\n          </div>\n        </div>\n\n        \n        <div class=\"col-span-12 lg:col-span-3 row-span-4 bento-card bg-white p-10\" data-kid=\"75\">\n          <h4 class=\"font-heading font-bold text-[#0d1f38] text-xl mb-8 flex items-center gap-2\" data-kid=\"76\">\n            <i class=\"ti ti-list-numbers text-[#0f59d4]\" data-kid=\"77\"></i>\n            Execution Path\n          </h4>\n          <div class=\"space-y-8\" data-kid=\"78\">\n            <div class=\"flex gap-5 group/item\" data-kid=\"79\">\n              <div class=\"shrink-0 w-12 h-12 rounded-full bg-[#eef4ff] text-[#0f59d4] flex items-center justify-center font-bold text-base border border-[#dce9ff] group-hover/item:bg-[#0f59d4] group-hover/item:text-white transition-all\" data-kid=\"80\">01</div>\n              <div data-kid=\"81\">\n                <p class=\"font-bold text-[#0d1f38] text-base mb-1\" data-kid=\"82\">Thermal Analysis</p>\n                <p class=\"text-sm text-gray-500 leading-relaxed\" data-kid=\"83\">Infrared fabric check for deep-seated allergens.</p>\n              </div>\n            </div>\n            <div class=\"flex gap-5 group/item\" data-kid=\"84\">\n              <div class=\"shrink-0 w-12 h-12 rounded-full bg-[#fff8e1] text-[#e8a800] flex items-center justify-center font-bold text-base border border-[#fdd36a] group-hover/item:bg-[#e8a800] group-hover/item:text-white transition-all\" data-kid=\"85\">02</div>\n              <div data-kid=\"86\">\n                <p class=\"font-bold text-[#0d1f38] text-base mb-1\" data-kid=\"87\">Bio-Clean Extract</p>\n                <p class=\"text-sm text-gray-500 leading-relaxed\" data-kid=\"88\">Hypoallergenic chemical-free deep wash.</p>\n              </div>\n            </div>\n            <div class=\"flex gap-5 group/item\" data-kid=\"89\">\n              <div class=\"shrink-0 w-12 h-12 rounded-full bg-[#eef4ff] text-[#0f59d4] flex items-center justify-center font-bold text-base border border-[#dce9ff] group-hover/item:bg-[#0f59d4] group-hover/item:text-white transition-all\" data-kid=\"90\">03</div>\n              <div data-kid=\"91\">\n                <p class=\"font-bold text-[#0d1f38] text-base mb-1\" data-kid=\"92\">Nano-Shield finish</p>\n                <p class=\"text-sm text-gray-500 leading-relaxed\" data-kid=\"93\">Protective coating against future spills.</p>\n              </div>\n            </div>\n          </div>\n        </div>\n\n        \n        <div class=\"col-span-12 lg:col-span-3 row-span-4 bento-card bg-[#f8faff] p-10\" data-kid=\"94\">\n          <h4 class=\"font-heading font-bold text-[#0d1f38] text-xl mb-8\" data-kid=\"95\">Service Metrics</h4>\n          <div class=\"space-y-6\" data-kid=\"96\">\n            <div class=\"p-4 bg-white rounded-2xl shadow-sm border border-gray-100 flex items-center justify-between\" data-kid=\"97\">\n              <span class=\"text-gray-500 text-sm font-medium\" data-kid=\"98\">Time Taken</span>\n              <span class=\"font-bold text-[#0d1f38]\" data-kid=\"99\">120 mins</span>\n            </div>\n            <div class=\"p-4 bg-white rounded-2xl shadow-sm border border-gray-100 flex items-center justify-between\" data-kid=\"100\">\n              <span class=\"text-gray-500 text-sm font-medium\" data-kid=\"101\">Water Usage</span>\n              <span class=\"font-bold text-[#0f59d4]\" data-kid=\"102\">-40% Efficiency</span>\n            </div>\n            <div class=\"p-4 bg-white rounded-2xl shadow-sm border border-gray-100 flex items-center justify-between\" data-kid=\"103\">\n              <span class=\"text-gray-500 text-sm font-medium\" data-kid=\"104\">Drying Time</span>\n              <span class=\"font-bold text-[#e8a800]\" data-kid=\"105\">4 Hours Max</span>\n            </div>\n          </div>\n          <div class=\"mt-8\" data-kid=\"106\">\n            <h5 class=\"text-xs font-bold uppercase tracking-widest text-[#8fa3c0] mb-4\" data-kid=\"107\">What's included</h5>\n            <div class=\"flex flex-wrap gap-2\" data-kid=\"108\">\n              <span class=\"px-3 py-1 bg-[#eef4ff] text-[#0f59d4] text-[10px] font-bold rounded-md border border-[#dce9ff]\" data-kid=\"109\">ANTIVIRAL</span>\n              <span class=\"px-3 py-1 bg-[#fff8e1] text-[#e8a800] text-[10px] font-bold rounded-md border border-[#fdd36a]\" data-kid=\"110\">PREMIUM WAX</span>\n              <span class=\"px-3 py-1 bg-[#eef4ff] text-[#0f59d4] text-[10px] font-bold rounded-md border border-[#dce9ff]\" data-kid=\"111\">pH BALANCED</span>\n            </div>\n          </div>\n        </div>\n\n        \n        <div class=\"col-span-12 lg:col-span-6 row-span-2 bento-card bg-[#e8a800] p-8 flex items-center justify-between border-none\" data-kid=\"112\">\n          <div class=\"flex items-center gap-6\" data-kid=\"113\">\n            <div class=\"w-16 h-16 bg-white/20 backdrop-blur-xl rounded-2xl flex items-center justify-center text-white text-3xl border border-white/30\" data-kid=\"114\">\n          