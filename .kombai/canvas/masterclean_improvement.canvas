flex items-center justify-center group-hover:scale-110 transition-transform\" data-kid=\"177\">\n                  <i class=\"ti ti-sofa text-3xl text-[var(--gray-400)] peer-checked:text-[var(--brand-blue)]\" data-kid=\"178\"></i>\n                </div>\n                <span class=\"font-black text-[var(--gray-900)]\" data-kid=\"179\">Estofado</span>\n              </div>\n            </label>\n            <label class=\"cursor-pointer group\" data-kid=\"180\">\n              <input type=\"radio\" name=\"service\" class=\"peer hidden\" data-kid=\"181\">\n              <div class=\"p-8 rounded-[28px] border-2 border-[var(--gray-100)] peer-checked:border-[var(--brand-blue)] peer-checked:bg-[var(--blue-50)] transition-all flex flex-col items-center gap-4 hover:border-[var(--blue-200)]\" data-kid=\"182\">\n                <div class=\"w-14 h-14 rounded-full bg-[var(--gray-50)] flex items-center justify-center group-hover:scale-110 transition-transform\" data-kid=\"183\">\n                  <i class=\"ti ti-car text-3xl text-[var(--gray-400)] peer-checked:text-[var(--brand-blue)]\" data-kid=\"184\"></i>\n                </div>\n                <span class=\"font-black text-[var(--gray-900)]\" data-kid=\"185\">Veículo</span>\n              </div>\n            </label>\n          </div>\n\n          <div class=\"space-y-6\" data-kid=\"186\">\n            <div data-kid=\"187\">\n              <label class=\"block text-sm font-black text-[var(--gray-700)] uppercase tracking-widest mb-3\" data-kid=\"188\">Tamanho / Quantidade</label>\n              <div class=\"relative\" data-kid=\"189\">\n                <select class=\"w-full p-5 rounded-2xl border-2 border-[var(--gray-100)] bg-[var(--gray-50)] outline-none appearance-none focus:border-[var(--brand-blue)] transition-colors font-bold text-[var(--gray-900)]\" data-kid=\"190\">\n                  <option data-kid=\"191\">Sofá 2 lugares</option>\n                  <option data-kid=\"192\">Sofá 3 lugares</option>\n                  <option data-kid=\"193\">Sofá Retrátil (L)</option>\n                  <option data-kid=\"194\">Poltrona Individual</option>\n                </select>\n                <div class=\"absolute right-5 top-1/2 -translate-y-1/2 pointer-events-none text-[var(--gray-400)]\" data-kid=\"195\">\n                  <i class=\"ti ti-chevron-down text-xl\" data-kid=\"196\"></i>\n                </div>\n              </div>\n            </div>\n          </div>\n\n          <div class=\"mt-8 p-8 rounded-[32px] bg-[var(--gray-900)] text-white flex flex-wrap justify-between items-center gap-6\" data-kid=\"197\">\n            <div data-kid=\"198\">\n              <p class=\"text-xs font-black text-white/50 uppercase tracking-[3px] mb-2\" data-kid=\"199\">Valor Estimado</p>\n              <p class=\"text-4xl font-black\" data-kid=\"200\">R$ 180<span class=\"text-lg font-bold text-white/40\" data-kid=\"201\">,00</span></p>\n            </div>\n            <button class=\"btn-gold py-4 px-10 text-sm\" data-kid=\"202\">Próximo Passo <i class=\"ti ti-arrow-right\" data-kid=\"203\"></i></button>\n          </div>\n        </div>\n\n        \n        <div data-kid=\"204\">\n          <span class=\"section-eyebrow\" data-kid=\"205\">Simule Agora</span>\n          <h2 class=\"text-5xl font-black mb-6 leading-tight\" data-kid=\"206\">Orçamento <span class=\"text-[var(--brand-blue)]\" data-kid=\"207\">transparente</span>, sem surpresas.</h2>\n          <p class=\"text-lg text-[var(--text-secondary)] mb-8 leading-relaxed\" data-kid=\"208\">\n            Nossa ferramenta utiliza inteligência de precificação para te dar uma estimativa real em segundos. Ganhe tempo e garanta sua vaga.\n          </p>\n          \n          <div class=\"space-y-8\" data-kid=\"209\">\n            <div class=\"flex gap-6\" data-kid=\"210\">\n              <div class=\"icon-circle blue shrink-0 shadow-lg\" data-kid=\"211\">\n                <i class=\"ti ti-clock-check text-2xl\" data-kid=\"212\"></i>\n              </div>\n              <div data-kid=\"213\">\n                <h4 class=\"text-xl font-black mb-1\" data-kid=\"214\">Resultado Instantâneo</h4>\n                <p class=\"text-[var(--text-secondary)]\" data-kid=\"215\">Saiba quanto vai investir em menos de 1 minuto.</p>\n              </div>\n            </div>\n            <div class=\"flex gap-6\" data-kid=\"216\">\n              <div class=\"icon-circle blue shrink-0 shadow-lg\" data-kid=\"217\">\n                <i class=\"ti ti-shield-lock text-2xl\" data-kid=\"218\"></i>\n              </div>\n              <div data-kid=\"219\">\n                <h4 class=\"text-xl font-black mb-1\" data-kid=\"220\">Preço Garantido</h4>\n                <p class=\"text-[var(--text-secondary)]\" data-kid=\"221\">O valor estimado é mantido por 48h após a simulação.</p>\n              </div>\n            </div>\n          </div>\n        </div>\n      </div>\n    </div>\n  </section>\n\n  \n  <section class=\"section-padding bg-white\" data-kid=\"222\">\n    <div class=\"container\" data-kid=\"223\">\n      <div class=\"grid lg:grid-cols-2 gap-16 items-center\" data-kid=\"224\">\n        <div data-kid=\"225\">\n          <span class=\"section-eyebrow\" data-kid=\"226\">Onde Estamos</span>\n          <h2 class=\"text-5xl font-black mb-8 leading-[1.2]\" data-kid=\"227\">Pronto para agendar sua <span class=\"text-[var(--brand-blue)]\" data-kid=\"228\">transformação?</span></h2>\n          \n          <div class=\"space-y-8 mb-12\" data-kid=\"229\">\n            <div class=\"flex items-center gap-6 group\" data-kid=\"230\">\n              <div class=\"icon-circle blue group-hover:bg-[var(--brand-blue)] group-hover:text-white transition-all shadow-md\" data-kid=\"231\">\n                <i class=\"ti ti-map-pin text-2xl\" data-kid=\"232\"></i>\n              </div>\n              <div data-kid=\"233\">\n                <p class=\"text-xs font-black text-[var(--text-muted)] uppercase tracking-widest\" data-kid=\"234\">Sede Central</p>\n                <p class=\"text-xl font-bold\" data-kid=\"235\">Av. Paulista, 1000 - São Paulo, SP</p>\n              </div>\n            </div>\n            <div class=\"flex items-center gap-6 group\" data-kid=\"236\">\n              <div class=\"icon-circle blue group-hover:bg-[var(--brand-blue)] group-hover:text-white transition-all shadow-md\" data-kid=\"237\">\n                <i class=\"ti ti-phone text-2xl\" data-kid=\"238\"></i>\n              </div>\n              <div data-kid=\"239\">\n                <p class=\"text-xs font-black text-[var(--text-muted)] uppercase tracking-widest\" data-kid=\"240\">Fale Conosco</p>\n                <p class=\"text-xl font-bold\" data-kid=\"241\">(11) 98765-4321</p>\n              </div>\n            </div>\n          </div>\n\n          <form class=\"space-y-6\" data-kid=\"242\">\n            <input type=\"text\" placeholder=\"Seu Nome Completo\" class=\"w-full p-5 rounded-2xl border-2 border-[var(--gray-100)] focus:border-[var(--brand-blue)] outline-none transition-colors font-bold\" data-kid=\"243\">\n            <div class=\"grid grid-cols-2 gap-6\" data-kid=\"244\">\n              <input type=\"email\" placeholder=\"Seu E-mail\" class=\"w-full p-5 rounded-2xl border-2 border-[var(--gray-100)] focus:border-[var(--brand-blue)] outline-none transition-colors font-bold\" data-kid=\"245\">\n              <input type=\"tel\" placeholder=\"Seu WhatsApp\" class=\"w-full p-5 rounded-2xl border-2 border-[var(--gray-100)] focus:border-[var(--brand-blue)] outline-none transition-colors font-bold\" data-kid=\"246\">\n            </div>\n            <textarea placeholder=\"Como podemos ajudar hoje?\" rows=\"4\" class=\"w-full p-5 rounded-2xl border-2 border-[var(--gray-100)] focus:border-[var(--brand-blue)] outline-none transition-colors font-bold\" data-kid=\"247\"></textarea>\n            <button class=\"btn-primary w-full justify-center py-6 text-lg\" data-kid=\"248\">\n              Enviar Mensagem Agora\n            </button>\n          </form>\n        </div>\n\n        <div class=\"relative h-[700px] rounded-[50px] overflow-hidden shadow-2xl border-[16px] border-[var(--gray-50)]\" data-kid=\"249\">\n          \n          <img src=\"https://images.unsplash.com/photo-1621639532859-8b26570b96fc?auto=format&w=1200&q=80&fit=crop\" alt=\"Map Location\" class=\"w-full h-full object-cover filter brightness-50\" decoding=\"async\" loading=\"lazy\" data-kid=\"250\">\n          \n          \n          <div class=\"absolute bottom-16 left-1/2 -translate-x-1/2 bg-white/95 backdrop-blur-xl p-6 rounded-[32px] shadow-2xl flex items-center gap-6 border border-white min-w-[340px] transform hover:scale-105 transition-transform\" data-kid=\"251\">\n            <div class=\"w-16 h-16 rounded-2xl bg-[var(--brand-gold)] flex items-center justify-center text-[var(--gray-900)] shadow-lg\" data-kid=\"252\">\n              <i class=\"ti ti-map-pin text-3xl\" data-kid=\"253\"></i>\n            </div>\n            <div data-kid=\"254\">\n              <p class=\"text-sm font-black text-[var(--gray-900)] uppercase tracking-widest mb-1\" data-kid=\"255\">Localização</p>\n              <p class=\"font-bold text-[var(--text-secondary)]\" data-kid=\"256\">Atendemos toda Grande SP</p>\n              <p class=\"text-xs text-[var(--brand-blue)] font-black mt-1\" data-kid=\"257\">Ver Área de Atendimento <i class=\"ti ti-arrow-right\" data-kid=\"258\"></i></p>\n            </div>\n          </div>\n\n          \n          <div class=\"absolute inset-0 bg-gradient-to-t from-[var(--gray-900)]/60 to-transparent pointer-events-none\" data-kid=\"259\"></div>\n        </div>\n      </div>\n    </div>\n  </section>\n\n  \n  <footer class=\"bg-[var(--gray-900)] text-white relative\" data-kid=\"260\">\n    \n    <div class=\"absolute top-0 left-0 w-full h-[2px] bg-gradient-to-r from-[var(--brand-blue)] via-[var(--brand-gold)] to-[var(--brand-blue)]\" data-kid=\"261\"></div>\n    \n    <div class=\"container section-padding pb-16\" data-kid=\"262\">\n      <div class=\"grid md:grid-cols-4 gap-16 mb-20\" data-kid=\"263\">\n        <div class=\"col-span-1 md:col-span-1\" data-kid=\"264\">\n          <div class=\"flex items-center gap-3 mb-8\" data-kid=\"265\">\n            <div class=\"w-10 h-10 bg-[var(--brand-blue)] rounded-xl flex items-center justify-center text-white\" data-kid=\"266\">\n              <i class=\"ti ti-sparkles text-2xl\" data-kid=\"267\"></i>\n            </div>\n            <span class=\"text-2xl font-black tracking-tighter\" data-kid=\"268\">Master<span class=\"text-[var(--brand-gold)]\" data-kid=\"269\">Clean</span></span>\n          </div>\n          <p class=\"text-white/60 mb-8 leading-relaxed\" data-kid=\"270\">\n            Especialistas em transformar ambientes e veículos através da limpeza técnica de precisão e saúde Health+.\n          </p>\n          <div class=\"flex gap-4\" data-kid=\"271\">\n            <a href=\"#\" class=\"w-10 h-10 rounded-full bg-white/5 flex items-center justify-center hover:bg-[var(--brand-blue)] transition-colors\" data-kid=\"272\"><i class=\"ti ti-brand-instagram\" data-kid=\"273\"></i></a>\n            <a href=\"#\" class=\"w-10 h-10 rounded-full bg-white/5 flex items-center justify-center hover:bg-[var(--brand-blue)] transition-colors\" data-kid=\"274\"><i class=\"ti ti-brand-facebook\" data-kid=\"275\"></i></a>\n            <a href=\"#\" class=\"w-10 h-10 rounded-full bg-white/5 flex items-center justify-center hover:bg-[var(--brand-blue)] transition-colors\" data-kid=\"276\"><i class=\"ti ti-brand-whatsapp\" data-kid=\"277\"></i></a>\n          </div>\n        </div>\n\n        <div data-kid=\"278\">\n          <h4 class=\"text-lg font-black mb-8 uppercase tracking-widest\" data-kid=\"279\">Navegação</h4>\n          <ul class=\"space-y-4 text-white/60 font-bold text-sm\" data-kid=\"280\">\n            <li data-kid=\"281\"><a href=\"#\" class=\"hover:text-white transition-colors flex items-center gap-2\" data-kid=\"282\"><i class=\"ti ti-chevron-right text-[var(--brand-gold)]\" data-kid=\"283\"></i> Início</a></li>\n            <li data-kid=\"284\"><a href=\"#\" class=\"hover:text-white transition-colors flex items-center gap-2\" data-kid=\"285\"><i class=\"ti ti-chevron-right text-[var(--brand-gold)]\" data-kid=\"286\"></i> Sobre Nós</a></li>\n            <li data-kid=\"287\"><a href=\"#\" class=\"hover:text-white transition-colors flex items-center gap-2\" data-kid=\"288\"><i class=\"ti ti-chevron-right text-[var(--brand-gold)]\" data-kid=\"289\"></i> Processos</a></li>\n            <li data-kid=\"290\"><a href=\"#\" class=\"hover:text-white transition-colors flex items-center gap-2\" data-kid=\"291\"><i class=\"ti ti-chevron-right text-[var(--brand-gold)]\" data-kid=\"292\"></i> Franquias</a></li>\n          </ul>\n        </div>\n\n        <div data-kid=\"293\">\n          <h4 class=\"text-lg font-black mb-8 uppercase tracking-widest\" data-kid=\"294\">Serviços</h4>\n          <ul class=\"space-y-4 text-white/60 font-bold text-sm\" data-kid=\"295\">\n            <li data-kid=\"296\"><a href=\"#\" class=\"hover:text-white transition-colors flex items-center gap-2\" data-kid=\"297\"><i class=\"ti ti-chevron-right text-[var(--brand-gold)]\" data-kid=\"298\"></i> Higienização de Sofás</a></li>\n            <li data-kid=\"299\"><a href=\"#\" class=\"hover:text-white transition-colors flex items-center gap-2\" data-kid=\"300\"><i class=\"ti ti-chevron-right text-[var(--brand-gold)]\" data-kid=\"301\"></i> Limpeza de Veículos</a></li>\n            <li data-kid=\"302\"><a href=\"#\" class=\"hover:text-white transition-colors flex items-center gap-2\" data-kid=\"303\"><i class=\"ti ti-chevron-right text-[var(--brand-gold)]\" data-kid=\"304\"></i> Tapetes Importados</a></li>\n            <li data-kid=\"305\"><a href=\"#\" class=\"hover:text-white transition-colors flex items-center gap-2\" data-kid=\"306\"><i class=\"ti ti-chevron-right text-[var(--brand-gold)]\" data-kid=\"307\"></i> Impermeabilização</a></li>\n          </ul>\n        </div>\n\n        <div data-kid=\"308\">\n          <h4 class=\"text-lg font-black mb-8 uppercase tracking-widest\" data-kid=\"309\">Newsletter</h4>\n          <p class=\"text-white/60 text-sm mb-6 font-bold\" data-kid=\"310\">Receba dicas de manutenção e ofertas exclusivas.</p>\n          <div class=\"relative\" data-kid=\"311\">\n            <input type=\"email\" placeholder=\"Seu melhor e-mail\" class=\"w-full p-4 rounded-2xl bg-white/5 border border-white/10 outline-none focus:border-[var(--brand-blue)] transition-colors font-bold text-sm\" data-kid=\"312\">\n            <button class=\"absolute right-2 top-2 w-10 h-10 bg-[var(--brand-blue)] rounded-xl flex items-center justify-center\" data-kid=\"313\"><i class=\"ti ti-send\" data-kid=\"314\"></i></button>\n          </div>\n        </div>\n      </div>\n\n      <div class=\"pt-12 border-t border-white/10 flex flex-wrap justify-between items-center gap-8\" data-kid=\"315\">\n        <p class=\"text-white/40 text-sm font-bold\" data-kid=\"316\">© 2024 MasterClean. Todos os direitos reservados. Precisão Minimalista.</p>\n        <div class=\"flex gap-8 text-white/40 text-sm font-bold\" data-kid=\"317\">\n          <a href=\"#\" class=\"hover:text-white transition-colors\" data-kid=\"318\">Termos de Uso</a>\n          <a href=\"#\" class=\"hover:text-white transition-colors\" data-kid=\"319\">Privacidade</a>\n        </div>\n      </div>\n    </div>\n  </footer>\n</div>\n",
