      "html": "<div class=\"relative bg-white font-sans text-[#0d1f38] leading-relaxed overflow-x-hidden\" data-kid=\"0\">\n  <style data-kid=\"1\">\n    @import url('https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&family=Outfit:wght@300;400;500;600;700;800;900&display=swap');\n    @import url('https://cdn.jsdelivr.net/npm/@tabler/icons-webfont/tabler-icons.min.css');\n\n    :root {\n      --blue-900: #042470;\n      --blue-800: #063490;\n      --blue-700: #0a46b0;\n      --blue-600: #0f59d4;\n      --blue-500: #1a6ef5;\n      --brand-gold: #f9b800;\n      --gold-300: #fdd36a;\n      --off-white: #f8faff;\n      --gray-900: #0d1f38;\n      --gray-600: #4a6080;\n      --gray-200: #c8d9ef;\n      --gray-100: #e4ecf7;\n    }\n\n    .font-heading { font-family: 'Outfit', sans-serif; }\n    .font-sans { font-family: 'Inter', sans-serif; }\n\n    .glass-nav {\n      background: rgba(13, 31, 56, 0.9);\n      backdrop-filter: blur(12px);\n      border: 1px solid rgba(255, 255, 255, 0.1);\n    }\n\n    .glass-card {\n      background: rgba(255, 255, 255, 0.85);\n      backdrop-filter: blur(20px);\n      border: 1px solid rgba(255, 255, 255, 0.5);\n    }\n\n    .bg-grid-subtle {\n      background-image: radial-gradient(rgba(111, 163, 245, 0.2) 1px, transparent 1px);\n      background-size: 40px 40px;\n    }\n\n    .bg-dots-gold {\n      background-image: radial-gradient(rgba(249, 184, 0, 0.1) 1.5px, transparent 1.5px);\n      background-size: 32px 32px;\n    }\n\n    .slider-handle-glow {\n      box-shadow: 0 0 20px rgba(249, 184, 0, 0.5), 0 0 40px rgba(249, 184, 0, 0.2);\n    }\n\n    .btn-gold {\n      background: linear-gradient(135deg, #f9b800 0%, #e8a800 100%);\n      color: #0d1f38;\n      transition: all 0.3s ease;\n      box-shadow: 0 4px 15px rgba(249, 184, 0, 0.35);\n    }\n    .btn-gold:hover {\n      transform: translateY(-2px);\n      box-shadow: 0 8px 25px rgba(249, 184, 0, 0.5);\n    }\n\n    .btn-primary {\n      background: linear-gradient(135deg, #1a6ef5 0%, #0a46b0 100%);\n      color: white;\n      transition: all 0.3s ease;\n      box-shadow: 0 4px 15px rgba(26, 110, 245, 0.3);\n    }\n    .btn-primary:hover {\n      transform: translateY(-2px);\n      box-shadow: 0 8px 25px rgba(26, 110, 245, 0.4);\n    }\n\n    .btn-outline-white {\n      background: transparent;\n      color: white;\n      border: 2px solid rgba(255, 255, 255, 0.4);\n      transition: all 0.3s ease;\n    }\n    .btn-outline-white:hover {\n      background: rgba(255, 255, 255, 0.1);\n      border-color: white;\n    }\n\n    .service-icon-hover:hover i {\n      transform: rotate(360deg) scale(1.1);\n      transition: all 0.8s cubic-bezier(0.34, 1.56, 0.64, 1);\n    }\n  </style>\n\n  \n  <nav class=\"absolute top-0 left-0 w-full z-50 px-6 py-4\" data-kid=\"2\">\n    <div class=\"max-w-[1180px] mx-auto flex items-center justify-between glass-nav rounded-full px-8 py-3 shadow-2xl\" data-kid=\"3\">\n      <div class=\"flex items-center gap-2\" data-kid=\"4\">\n        <div class=\"w-10 h-10 bg-[#f9b800] rounded-lg flex items-center justify-center rotate-3 shadow-lg\" data-kid=\"5\">\n          <i class=\"ti ti-sparkles text-[#0d1f38] text-2xl\" data-kid=\"6\"></i>\n        </div>\n        <span class=\"font-heading text-2xl font-black text-white tracking-tight\" data-kid=\"7\">Master<span class=\"text-[#f9b800]\" data-kid=\"8\">Clean</span></span>\n      </div>\n      <div class=\"hidden md:flex items-center gap-8 text-white/90 font-medium text-sm uppercase tracking-wider\" data-kid=\"9\">\n        <a href=\"#hero\" class=\"hover:text-[#f9b800] transition-colors\" data-kid=\"10\">Início</a>\n        <a href=\"#services\" class=\"hover:text-[#f9b800] transition-colors\" data-kid=\"11\">Serviços</a>\n        <a href=\"#before-after\" class=\"hover:text-[#f9b800] transition-colors\" data-kid=\"12\">Resultados</a>\n        <a href=\"#estimator\" class=\"hover:text-[#f9b800] transition-colors\" data-kid=\"13\">Orçamento</a>\n      </div>\n      <button class=\"btn-gold px-8 py-2.5 rounded-full font-bold text-sm tracking-wide shadow-xl\" data-kid=\"14\">\n        Agendar Agora\n      </button>\n    </div>\n  </nav>\n\n  \n  <section id=\"hero\" class=\"relative bg-[#042470] min-h-[850px] flex items-center overflow-hidden\" data-kid=\"15\">\n    <div class=\"absolute inset-0 bg-grid-subtle opacity-10\" data-kid=\"16\"></div>\n    <div class=\"absolute top-[-20%] right-[-10%] w-[800px] h-[800px] bg-[#f9b800] opacity-5 blur-[150px] rounded-full\" data-kid=\"17\"></div>\n    \n    <div class=\"max-w-[1180px] mx-auto px-6 grid md:grid-cols-2 gap-20 items-center relative z-10 py-32\" data-kid=\"18\">\n      <div class=\"space-y-10\" data-kid=\"19\">\n        <div class=\"inline-flex items-center gap-2 px-5 py-2 bg-white/10 backdrop-blur-md border border-white/20 rounded-full text-[#f9b800] font-bold text-xs tracking-[0.2em] uppercase\" data-kid=\"20\">\n          <i class=\"ti ti-shield-check\" data-kid=\"21\"></i> Higienização Profissional Dinâmica\n        </div>\n        <h1 class=\"font-heading text-7xl md:text-9xl font-black text-white leading-[0.85] tracking-tighter relative\" data-kid=\"22\">\n          Limpeza <br data-kid=\"23\">\n          <span class=\"text-[#f9b800] italic drop-shadow-[0_0_30px_rgba(249,184,0,0.4)]\" data-kid=\"24\">Master</span>. <br data-kid=\"25\">\n          Sua Saúde.\n          <div class=\"absolute -top-10 -right-20 w-32 h-32 bg-[#f9b800]/20 blur-3xl rounded-full\" data-kid=\"26\"></div>\n        </h1>\n        <p class=\"text-white text-xl max-w-lg leading-relaxed font-medium opacity-90\" data-kid=\"27\">\n          Transformamos ambientes através da higienização técnica profunda. <span class=\"text-[#f9b800]\" data-kid=\"28\">Excelência comprovada</span> em sofás, carpetes e interiores automotivos.\n        </p>\n        <div class=\"flex flex-wrap gap-6 pt-4\" data-kid=\"29\">\n          <button class=\"btn-gold !px-12 !py-5 text-lg font-black uppercase tracking-widest rounded-full\" data-kid=\"30\">\n            Simular Preço <i class=\"ti ti-chevron-right ml-2\" data-kid=\"31\"></i>\n          </button>\n          <button class=\"btn-outline-white !px-12 !py-5 text-lg font-bold rounded-full\" data-kid=\"32\">\n            WhatsApp\n          </button>\n        </div>\n      </div>\n\n      <div class=\"relative\" data-kid=\"33\">\n        <div class=\"relative rounded-[50px] overflow-hidden shadow-[0_30px_60px_-15px_rgba(0,0,0,0.5)] border-[12px] border-white/5 group\" data-kid=\"34\">\n          <img src=\"https://images.unsplash.com/photo-1638885930125-85350348d266?auto=format&w=1200&q=80&fit=crop\" class=\"w-full h-[650px] object-cover transition-transform duration-1000 group-hover:scale-110\" alt=\"MasterClean\" decoding=\"async\" loading=\"lazy\" data-kid=\"35\">\n          <div class=\"absolute inset-0 bg-gradient-to-t from-[#042470]/80 via-transparent to-transparent\" data-kid=\"36\"></div>\n          \n          <div class=\"absolute bottom-12 left-12 right-12 p-8 glass-nav rounded-3xl flex items-center justify-between border border-white/20 shadow-2xl\" data-kid=\"37\">\n            <div data-kid=\"38\">\n              <p class=\"text-[#f9b800] font-black text-xs uppercase tracking-widest mb-1\" data-kid=\"39\">Status do Atendimento</p>\n              <p class=\"text-white font-black text-2xl tracking-tight\" data-kid=\"40\">Equipe Disponível Hoje</p>\n            </div>\n            <div class=\"w-16 h-16 bg-[#f9b800] rounded-full flex items-center justify-center text-[#0d1f38] text-3xl shadow-2xl animate-pulse\" data-kid=\"41\">\n              <i class=\"ti ti-calendar-check\" data-kid=\"42\"></i>\n            </div>\n          </div>\n        </div>\n      </div>\n    </div>\n  </section>\n\n  \n  <section id=\"services\" class=\"py-32 relative bg-[#f8faff] overflow-hidden\" data-kid=\"43\">\n    <div class=\"absolute inset-0 bg-dots-gold opacity-[0.03]\" data-kid=\"44\"></div>\n    <div class=\"max-w-[1180px] mx-auto px-6 relative z-10\" data-kid=\"45\">\n      <div class=\"text-center max-w-3xl mx-auto mb-20 space-y-4\" data-kid=\"46\">\n        <span class=\"inline-block px-4 py-1.5 bg-[#1a6ef5]/10 text-[#0f59d4] rounded-full text-[10px] font-black uppercase tracking-[0.2em] border border-[#1a6ef5]/20\" data-kid=\"47\">Especialidades</span>\n        <h2 class=\"font-heading text-5xl font-black text-[#0d1f38] tracking-tight\" data-kid=\"48\">O que fazemos por <span class=\"text-[#1a6ef5]\" data-kid=\"49\">Você</span></h2>\n        <div class=\"w-20 h-1.5 bg-[#f9b800] mx-auto rounded-full\" data-kid=\"50\"></div>\n      </div>\n\n      <div class=\"grid md:grid-cols-3 gap-10 items-stretch\" data-kid=\"51\">\n        \n        <div class=\"group glass-card p-12 rounded-[40px] shadow-xl hover:shadow-2xl transition-all duration-500 relative overflow-hidden service-icon-hover border border-[#e4ecf7] hover:border-[#1a6ef5]/40 hover:-translate-y-2\" data-kid=\"52\">\n          <div class=\"absolute top-0 right-0 w-48 h-48 bg-[#1a6ef5]/5 rounded-bl-full -mr-24 -mt-24 group-hover:scale-150 transition-transform duration-1000\" data-kid=\"53\"></div>\n          <div class=\"w-20 h-20 rounded-2xl bg-[#1a6ef5]/10 flex items-center justify-center text-[#1a6ef5] mb-10 transition-all duration-500 group-hover:bg-[#1a6ef5] group-hover:text-white group-hover:shadow-[0_15px_30px_rgba(26,110,245,0.4)] relative z-10\" data-kid=\"54\">\n            <i class=\"ti ti-armchair text-4xl\" data-kid=\"55\"></i>\n          </div>\n          <h3 class=\"font-heading text-3xl font-black mb-6 text-[#0d1f38]\" data-kid=\"56\">Estofados</h3>\n          <p class=\"text-[#4a6080] mb-10 text-lg leading-relaxed\" data-kid=\"57\">Higienização técnica com extração a vácuo, removendo 99.9% de ácaros, fungos e odores.</p>\n          <ul class=\"space-y-4 mb-10\" data-kid=\"58\">\n            <li class=\"flex items-center gap-3 font-bold text-sm text-[#0d1f38]\" data-kid=\"59\">\n              <div class=\"w-5 h-5 rounded-full bg-green-500/10 text-green-600 flex items-center justify-center text-[10px]\" data-kid=\"60\"><i class=\"ti ti-check\" data-kid=\"61\"></i></div>\n              Secagem Rápida (4h)\n            </li>\n            <li class=\"flex items-center gap-3 font-bold text-sm text-[#0d1f38]\" data-kid=\"62\">\n              <div class=\"w-5 h-5 rounded-full bg-green-500/10 text-green-600 flex items-center justify-center text-[10px]\" data-kid=\"63\"><i class=\"ti ti-check\" data-kid=\"64\"></i></div>\n              Produtos Biodegradáveis\n            </li>\n          </ul>\n          <button class=\"w-full py-4 rounded-2xl font-black text-xs uppercase tracking-widest border-2 border-[#1a6ef5] text-[#1a6ef5] hover:bg-[#1a6ef5] hover:text-white transition-all\" data-kid=\"65\">Ver Detalhes</button>\n        </div>\n\n        \n        <div class=\"group bg-white p-12 rounded-[40px] shadow-2xl relative overflow-hidden border-2 border-[#f9b800] md:-translate-y-8 transition-all duration-500 hover:-translate-y-12\" data-kid=\"66\">\n          <div class=\"absolute top-6 right-6 bg-[#f9b800] text-[#0d1f38] px-4 py-1.5 rounded-full text-[10px] font-black uppercase tracking-widest shadow-lg\" data-kid=\"67\">Mais Procurado</div>\n          <div class=\"w-20 h-20 rounded-2xl bg-[#f9b800]/10 flex items-center justify-center text-[#f9b800] mb-10 transition-all duration-500 group-hover:bg-[#f9b800] group-hover:text-[#0d1f38] group-hover:shadow-[0_15px_30px_rgba(249,184,0,0.4)]\" data-kid=\"68\">\n            <i class=\"ti ti-car text-4xl\" data-kid=\"69\"></i>\n          </div>\n          <h3 class=\"font-heading text-3xl font-black mb-6 text-[#0d1f38]\" data-kid=\"70\">Automotivo</h3>\n          <p class=\"text-[#4a6080] mb-10 text-lg leading-relaxed\" data-kid=\"71\">Limpeza detalhada de bancos, teto, carpetes e cintos. Revitalização completa para seu carro.</p>\n          <ul class=\"space-y-4 mb-10\" data-kid=\"72\">\n            <li class=\"flex items-center gap-3 font-bold text-sm text-[#0d1f38]\" data-kid=\"73\">\n              <div class=\"w-5 h-5 rounded-full bg-[#f9b800]/20 text-[#0d1f38] flex items-center justify-center text-[10px]\" data-kid=\"74\"><i class=\"ti ti-check\" data-kid=\"75\"></i></div>\n              Hidratação de Couro\n            </li>\n            <li class=\"flex items-center gap-3 font-bold text-sm text-[#0d1f38]\" data-kid=\"76\">\n              <div class=\"w-5 h-5 rounded-full bg-[#f9b800]/20 text-[#0d1f38] flex items-center justify-center text-[10px]\" data-kid=\"77\"><i class=\"ti ti-check\" data-kid=\"78\"></i></div>\n              Oxi-sanitização Inclusa\n            </li>\n          </ul>\n          <button class=\"btn-gold w-full py-4 rounded-2xl font-black text-xs uppercase tracking-widest shadow-xl\" data-kid=\"79\">Contratar Agora</button>\n        </div>\n\n        \n        <div class=\"group glass-card p-12 rounded-[40px] shadow-xl hover:shadow-2xl transition-all duration-500 relative overflow-hidden service-icon-hover border border-[#e4ecf7] hover:border-[#1a6ef5]/40 hover:-translate-y-2\" data-kid=\"80\">\n          <div class=\"absolute top-0 right-0 w-48 h-48 bg-[#1a6ef5]/5 rounded-bl-full -mr-24 -mt-24 group-hover:scale-150 transition-transform duration-1000\" data-kid=\"81\"></div>\n          <div class=\"w-20 h-20 rounded-2xl bg-[#1a6ef5]/10 flex items-center justify-center text-[#1a6ef5] mb-10 transition-all duration-500 group-hover:bg-[#1a6ef5] group-hover:text-white group-hover:shadow-[0_15px_30px_rgba(26,110,245,0.4)] relative z-10\" data-kid=\"82\">\n            <i class=\"ti ti-layers-intersect text-4xl\" data-kid=\"83\"></i>\n          </div>\n          <h3 class=\"font-heading text-3xl font-black mb-6 text-[#0d1f38]\" data-kid=\"84\">Tapetes</h3>\n          <p class=\"text-[#4a6080] mb-10 text-lg leading-relaxed\" data-kid=\"85\">Tratamento específico fibra a fibra, eliminando manchas e revitalizando as cores originais.</p>\n          <ul class=\"space-y-4 mb-10\" data-kid=\"86\">\n            <li class=\"flex items-center gap-3 font-bold text-sm text-[#0d1f38]\" data-kid=\"87\">\n              <div class=\"w-5 h-5 rounded-full bg-green-500/10 text-green-600 flex items-center justify-center text-[10px]\" data-kid=\"88\"><i class=\"ti ti-check\" data-kid=\"89\"></i></div>\n              Higienização Antimofo\n            </li>\n            <li class=\"flex items-center gap-3 font-bold text-sm text-[#0d1f38]\" data-kid=\"90\">\n              <div class=\"w-5 h-5 rounded-full bg-green-500/10 text-green-600 flex items-center justify-center text-[10px]\" data-kid=\"91\"><i class=\"ti ti-check\" data-kid=\"92\"></i></div>\n              Eliminação de Odores Pet\n            </li>\n          </ul>\n          <button class=\"w-full py-4 rounded-2xl font-black text-xs uppercase tracking-widest border-2 border-[#1a6ef5] text-[#1a6ef5] hover:bg-[#1a6ef5] hover:text-white transition-all\" data-kid=\"93\">Ver Detalhes</button>\n        </div>\n      </div>\n    </div>\n  </section>\n\n  \n  <section id=\"before-after\" class=\"py-32 bg-[#0d1f38] relative overflow-hidden\" data-kid=\"94\">\n    <div class=\"absolute inset-0 bg-grid-subtle opacity-5\" data-kid=\"95\"></div>\n    <div class=\"max-w-[1180px] mx-auto px-6 relative z-10\" data-kid=\"96\">\n      <div class=\"text-center mb-24 space-y-4\" data-kid=\"97\">\n        <span class=\"inline-block px-4 py-1.5 bg-white/5 text-[#f9b800] rounded-full text-[10px] font-black uppercase tracking-[0.2em] border border-white/10\" data-kid=\"98\">Resultados Reais</span>\n        <h2 class=\"font-heading text-5xl font-black text-white tracking-tight\" data-kid=\"99\">O Poder da <span class=\"text-[#f9b800]\" data-kid=\"100\">Transformação</span></h2>\n        <p class=\"text-white/50 text-xl font-medium\" data-kid=\"101\">Arraste o cursor dourado e veja a diferença em cada detalhe.</p>\n      </div>\n\n      <div class=\"max-w-[950px] mx-auto group\" data-kid=\"102\">\n        <div class=\"relative aspect-[16/9] rounded-[48px] overflow-hidden shadow-[0_40px_100px_-20px_rgba(0,0,0,0.8)] border border-white/10\" data-kid=\"103\">\n          <img src=\"https://images.unsplash.com/photo-1638885930125-85350348d266?auto=format&w=1400&q=80&fit=crop\" class=\"absolute inset-0 w-full h-full object-cover\" alt=\"After\" decoding=\"async\" loading=\"lazy\" data-kid=\"104\">\n          \n          <div class=\"absolute inset-0 w-1/2 overflow-hidden border-r-[4px] border-[#f9b800]\" id=\"ba-clip\" data-kid=\"105\">\n            <img src=\"https://images.unsplash.com/photo-1638885930125-85350348d266?auto=format&w=1400&q=80&fit=crop&sepia=80\" class=\"absolute inset-0 w-[950px] max-w-none h-full object-cover grayscale brightness-50 opacity-90\" alt=\"Before\" decoding=\"async\" loading=\"lazy\" data-kid=\"106\">\n            <div class=\"absolute top-10 left-10 glass-nav px-6 py-2 rounded-full text-white text-xs font-black uppercase tracking-widest border border-white/20\" data-kid=\"107\">Antes MasterClean</div>\n          </div>\n          \n          <div class=\"absolute top-10 right-10 bg-[#f9b800] px-6 py-2 rounded-full text-[#0d1f38] text-xs font-black uppercase tracking-widest border border-[#0d1f38]/20 shadow-2xl\" data-kid=\"108\">Depois MasterClean</div>\n\n          <div class=\"absolute top-0 bottom-0 left-1/2 -ml-[2px] w-[4px] bg-[#f9b800] flex items-center justify-center cursor-ew-resize\" data-kid=\"109\">\n             <div class=\"w-20 h-20 bg-[#f9b800] rounded-full flex items-center justify-center text-[#0d1f38] border-[6px] border-[#0d1f38] slider-handle-glow transition-all duration-500 group-hover:scale-110 shadow-[0_0_60px_rgba(249,184,0,0.9)]\" data-kid=\"110\">\n               <i class=\"ti ti-arrows-left-right text-3xl\" data-kid=\"111\"></i>\n             </div>\n          </div>\n        </div>\n      </div>\n    </div>\n  </section>\n\n  \n  <section id=\"estimator\" class=\"py-32 bg-[#f8faff] relative overflow-hidden\" data-kid=\"112\">\n    <div class=\"absolute top-0 right-0 w-1/3 h-full bg-[#042470] hidden lg:block\" data-kid=\"113\"></div>\n    <div class=\"max-w-[1180px] mx-auto px-6 relative z-10\" data-kid=\"114\">\n      <div class=\"max-w-[1000px] mx-auto bg-white rounded-[60px] shadow-[0_40px_80px_-20px_rgba(13,31,56,0.15)] overflow-hidden border border-[#e4ecf7]\" data-kid=\"115\">\n        <div class=\"grid lg:grid-cols-5\" data-kid=\"116\">\n          <div class=\"lg:col-span-3 p-16 space-y-12\" data-kid=\"117\">\n            <div data-kid=\"118\">\n              <h2 class=\"font-heading text-4xl font-black text-[#0d1f38] mb-4 tracking-tight\" data-kid=\"119\">Simulador de <span class=\"text-[#1a6ef5]\" data-kid=\"120\">Investimento</span></h2>\n              <p class=\"text-[#4a6080] text-lg\" data-kid=\"121\">Estimativa instantânea baseada nas suas necessidades reais.</p>\n            </div>\n            \n            <div class=\"space-y-8\" data-kid=\"122\">\n              <label class=\"block text-xs font-black uppercase tracking-[0.2em] text-[#8fa3c0]\" data-kid=\"123\">1. O que deseja higienizar?</label>\n              <div class=\"grid grid-cols-2 sm:grid-cols-4 gap-4\" data-kid=\"124\">\n                <button class=\"flex flex-col items-center justify-center p-6 rounded-3xl border-2 border-[#f9b800] bg-[#fff8e1] text-[#0d1f38] shadow-lg shadow-[#f9b800]/10\" data-kid=\"125\">\n                  <i class=\"ti ti-sofa text-3xl mb-3\" data-kid=\"126\"></i>\n                  <span class=\"text-xs font-black\" data-kid=\"127\">SOFÁ</span>\n                </button>\n                <button class=\"flex flex-col items-center justify-center p-6 rounded-3xl border-2 border-[#e4ecf7] hover:border-[#1a6ef5] transition-all text-[#4a6080] hover:text-[#1a6ef5]\" data-kid=\"128\">\n                  <i class=\"ti ti-car text-3xl mb-3\" data-kid=\"129\"></i>\n                  <span class=\"text-xs font-black\" data-kid=\"130\">CARRO</span>\n                </button>\n                <button class=\"flex flex-col items-center justify-center p-6 rounded-3xl border-2 border-[#e4ecf7] hover:border-[#1a6ef5] transition-all text-[#4a6080] hover:text-[#1a6ef5]\" data-kid=\"131\">\n                  <i class=\"ti ti-layers-intersect text-3xl mb-3\" data-kid=\"132\"></i>\n                  <span class=\"text-xs font-black\" data-kid=\"133\">TAPETE</span>\n                </button>\n                <button class=\"flex flex-col items-center justify-center p-6 rounded-3xl border-2 border-[#e4ecf7] hover:border-[#1a6ef5] transition-all text-[#4a6080] hover:text-[#1a6ef5]\" data-kid=\"134\">\n                  <i class=\"ti ti-bed text-3xl mb-3\" data-kid=\"135\"></i>\n                  <span class=\"text-xs font-black\" data-kid=\"136\">CAMA</span>\n                </button>\n              </div>\n            </div>\n\n            <div class=\"space-y-8\" data-kid=\"137\">\n              <label class=\"block text-xs font-black uppercase tracking-[0.2em] text-[#8fa3c0]\" data-kid=\"138\">2. Quantidade de Lugares / Medida</label>\n              <div class=\"relative pt-6\" data-kid=\"139\">\n                <input type=\"range\" class=\"w-full h-3 bg-[#e4ecf7] rounded-full appearance-none cursor-pointer accent-[#f9b800]\" min=\"1\" max=\"4\" value=\"2\" data-kid=\"140\">\n                <div class=\"flex justify-between mt-4 text-[10px] font-black text-[#8fa3c0] uppercase tracking-widest px-1\" data-kid=\"141\">\n                  <span data-kid=\"142\">1 Lugar</span>\n                  <span data-kid=\"143\">2 Lugares</span>\n                  <span data-kid=\"144\">3 Lugares</span>\n                  <span data-kid=\"145\">4+ Lugares</span>\n                </div>\n              </div>\n            </div>\n          </div>\n          \n          <div class=\"lg:col-span-2 bg-[#042470] p-16 flex flex-col justify-center items-center text-center text-white space-y-10 relative overflow-hidden\" data-kid=\"146\">\n            <div class=\"absolute inset-0 bg-grid-subtle opacity-10\" data-kid=\"147\"></div>\n            <div class=\"w-24 h-24 bg-white/10 rounded-3xl flex items-center justify-center text-4xl text-[#f9b800] shadow-2xl relative z-10 border border-white/10\" data-kid=\"148\">\n              <i class=\"ti ti-calculator\" data-kid=\"149\"></i>\n            </div>\n            <div class=\"relative z-10\" data-kid=\"150\">\n              <p class=\"text-[#f9b800] uppercase tracking-[0.3em] text-[10px] font-black mb-4\" data-kid=\"151\">Estimativa MasterClean</p>\n              <div class=\"text-7xl font-black text-white tracking-tighter\" data-kid=\"152\">R$ 180<span class=\"text-2xl text-[#f9b800]\" data-kid=\"153\">,00</span></div>\n            </div>\n            <button class=\"btn-gold w-full !py-6 !text-lg !font-black uppercase tracking-widest rounded-3xl shadow-2xl relative z-10\" data-kid=\"154\">Agendar Agora</button>\n            <p class=\"text-white/40 text-[10px] uppercase tracking-widest font-bold relative z-10\" data-kid=\"155\">Até 12x no cartão de crédito</p>\n          </div>\n        </div>\n      </div>\n    </div>\n  </section>\n\n  \n  <footer class=\"bg-[#0d1f38] text-white pt-32 pb-16 relative overflow-hidden\" data-kid=\"156\">\n    <div class=\"absolute top-0 left-0 w-full h-2 bg-gradient-to-r from-[#1a6ef5] via-[#f9b800] to-[#1a6ef5]\" data-kid=\"157\"></div>\n    <div class=\"max-w-[1180px] mx-auto px-6 grid md:grid-cols-4 gap-16 mb-24\" data-kid=\"158\">\n      <div class=\"space-y-10\" data-kid=\"159\">\n        <div class=\"flex items-center gap-2\" data-kid=\"160\">\n          <div class=\"w-12 h-12 bg-[#f9b800] rounded-xl flex items-center justify-center rotate-3 shadow-2xl\" data-kid=\"161\">\n            <i class=\"ti ti-sparkles text-[#0d1f38] text-2xl\" data-kid=\"162\"></i>\n          </div>\n          <span class=\"font-heading text-3xl font-black text-white tracking-tight\" data-kid=\"163\">Master<span class=\"text-[#f9b800]\" data-kid=\"164\">Clean</span></span>\n        </div>\n        <p class=\"text-white/50 text-lg leading-relaxed font-medium italic\" data-kid=\"165\">\"Excelência em cada detalhe, saúde em cada fibra.\"</p>\n        <div class=\"flex gap-4\" data-kid=\"166\">\n          <a href=\"#\" class=\"w-12 h-12 bg-white/5 rounded-2xl flex items-center justify-center hover:bg-[#1a6ef5] hover:-translate-y-1 transition-all duration-300 border border-white/10\" data-kid=\"167\"><i class=\"ti ti-brand-instagram text-xl\" data-kid=\"168\"></i></a>\n          <a href=\"#\" class=\"w-12 h-12 bg-white/5 rounded-2xl flex items-center justify-center hover:bg-[#1a6ef5] hover:-translate-y-1 transition-all duration-300 border border-white/10\" data-kid=\"169\"><i class=\"ti ti-brand-whatsapp text-xl\" data-kid=\"170\"></i></a>\n          <a href=\"#\" class=\"w-12 h-12 bg-white/5 rounded-2xl flex items-center justify-center hover:bg-[#1a6ef5] hover:-translate-y-1 transition-all duration-300 border border-white/10\" data-kid=\"171\"><i class=\"ti ti-brand-facebook text-xl\" data-kid=\"172\"></i></a>\n        </div>\n      </div>\n      \n      <div data-kid=\"173\">\n        <h4 class=\"font-black mb-10 uppercase tracking-[0.2em] text-[11px] text-[#f9b800]\" data-kid=\"174\">Serviços</h4>\n        <ul class=\"space-y-6 text-white/70 font-bold text-sm tracking-wide\" data-kid=\"175\">\n          <li data-kid=\"176\"><a href=\"#\" class=\"hover:text-[#f9b800] transition-colors\" data-kid=\"177\">Higienização de Sofás</a></li>\n          <li data-kid=\"178\"><a href=\"#\" class=\"hover:text-[#f9b800] transition-colors\" data-kid=\"179\">Interiores Automotivos</a></li>\n          <li data-kid=\"180\"><a href=\"#\" class=\"hover:text-[#f9b800] transition-colors\" data-kid=\"181\">Limpeza de Tapetes</a></li>\n          <li data-kid=\"182\"><a href=\"#\" class=\"hover:text-[#f9b800] transition-colors\" data-kid=\"183\">Impermeabilização</a></li>\n          <li data-kid=\"184\"><a href=\"#\" class=\"hover:text-[#f9b800] transition-colors\" data-kid=\"185\">Limpeza de Colchões</a></li>\n        </ul>\n      </div>\n\n      <div data-kid=\"186\">\n        <h4 class=\"font-black mb-10 uppercase tracking-[0.2em] text-[11px] text-[#f9b800]\" data-kid=\"187\">Institucional</h4>\n        <ul class=\"space-y-6 text-white/70 font-bold text-sm tracking-wide\" data-kid=\"188\">\n          <li data-kid=\"189\"><a href=\"#\" class=\"hover:text-[#f9b800] transition-colors\" data-kid=\"190\">Sobre a MasterClean</a></li>\n          <li data-kid=\"191\"><a href=\"#\" class=\"hover:text-[#f9b800] transition-colors\" data-kid=\"192\">Nossa Tecnologia</a></li>\n          <li data-kid=\"193\"><a href=\"#\" class=\"hover:text-[#f9b800] transition-colors\" data-kid=\"194\">Política de Saúde</a></li>\n          <li data-kid=\"195\"><a href=\"#\" class=\"hover:text-[#f9b800] transition-colors\" data-kid=\"196\">Trabalhe Conosco</a></li>\n          <li data-kid=\"197\"><a href=\"#\" class=\"hover:text-[#f9b800] transition-colors\" data-kid=\"198\">Blog & Dicas</a></li>\n        </ul>\n      </div>\n\n      <div data-kid=\"199\">\n        <h4 class=\"font-black mb-10 uppercase tracking-[0.2em] text-[10px] text-[#f9b800]\" data-kid=\"200\">Atendimento</h4>\n        <div class=\"space-y-8\" data-kid=\"201\">\n           <div class=\"flex items-center gap-4 group\" data-kid=\"202\">\n             <div class=\"w-10 h-10 bg-white/5 rounded-xl flex items-center justify-center text-[#f9b800] border border-white/10 group-hover:bg-[#f9b800] group-hover:text-[#0d1f38] transition-all\" data-kid=\"203\"><i class=\"ti ti-phone-filled\" data-kid=\"204\"></i></div>\n             <p class=\"font-black text-sm tracking-wider\" data-kid=\"205\">(11) 99999-9999</p>\n           </div>\n           <div class=\"flex items-center gap-4 group\" data-kid=\"206\">\n             <div class=\"w-10 h-10 bg-white/5 rounded-xl flex items-center justify-center text-[#f9b800] border border-white/10 group-hover:bg-[#f9b800] group-hover:text-[#0d1f38] transition-all\" data-kid=\"207\"><i class=\"ti ti-mail-filled\" data-kid=\"208\"></i></div>\n             <p class=\"font-black text-sm tracking-wider\" data-kid=\"209\">contato@masterclean.com</p>\n           </div>\n           <div class=\"pt-4\" data-kid=\"210\">\n             <div class=\"p-6 bg-white/5 rounded-3xl border border-white/10\" data-kid=\"211\">\n               <p class=\"text-[10px] font-black uppercase text-[#8fa3c0] mb-3 tracking-widest\" data-kid=\"212\">Horário de Funcionamento</p>\n               <p class=\"text-xs font-bold text-white/70\" data-kid=\"213\">Seg - Sáb: 08:00 às 19:00</p>\n             </div>\n           </div>\n        </div>\n      </div>\n    </div>\n    \n    <div class=\"max-w-[1180px] mx-auto px-6 pt-16 border-t border-white/5 flex flex-col md:grid md:grid-cols-2 items-center gap-8 text-[10px] font-black uppercase tracking-[0.25em] text-white/20 text-center md:text-left\" data-kid=\"214\">\n      <p data-kid=\"215\">© 2024 MasterClean Higienização. Todos os direitos reservados.</p>\n      <div class=\"flex justify-center md:justify-end gap-10\" data-kid=\"216\">\n        <a href=\"#\" class=\"hover:text-white transition-colors\" data-kid=\"217\">Privacidade</a>\n        <a href=\"#\" class=\"hover:text-white transition-colors\" data-kid=\"218\">Termos</a>\n      </div>\n    </div>\n  </footer>\n\n  \n  <div class=\"absolute bottom-10 right-10 z-[100] group pointer-events-auto\" data-kid=\"219\">\n    <div class=\"absolute -inset-4 bg-green-500/20 blur-2xl rounded-full opacity-0 group-hover:opacity-100 transition-opacity duration-500\" data-kid=\"220\"></div>\n    <a href=\"https://wa.me/5511999999999\" target=\"_blank\" class=\"relative w-20 h-20 bg-[#25D366] rounded-full flex items-center justify-center text-white text-5xl shadow-[0_20px_40px_-10px_rgba(37,211,102,0.5)] hover:scale-110 transition-all duration-300\" data-kid=\"221\">\n      <i class=\"ti ti-brand-whatsapp\" data-kid=\"222\"></i>\n    </a>\n  </div>\n\n</div>\n>>>>>>> REPLACE\n",
